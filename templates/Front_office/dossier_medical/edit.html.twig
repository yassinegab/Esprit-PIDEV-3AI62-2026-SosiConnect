{% extends 'base.html.twig' %}

{% block title %}Modifier Dossier Médical{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-gray-50">
    <div class="flex flex-1 flex-col">
        {% include 'components/top-nav.html.twig' %}

        <main class="flex-1 overflow-auto pb-12">
            <div class="mx-auto max-w-4xl space-y-8 p-4 lg:p-8">

                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900">
                            <i class="fas fa-edit text-blue-600 mr-3"></i>
                            Modifier Dossier Médical #{{ dossier_medical.id }}
                        </h1>
                        <p class="text-gray-600 mt-1">
                            Dernière mise à jour : {{ dossier_medical.derniereMiseAJour|date('d/m/Y H:i') }}
                        </p>
                    </div>
                    <a href="{{ path('dossier_medical_index') }}"
                       class="inline-flex items-center px-5 py-2.5 bg-gray-200 text-gray-700 font-semibold rounded-lg hover:bg-gray-300 transition">
                        <i class="fas fa-arrow-left mr-2"></i> Retour
                    </a>
                </div>

                {% for message in app.flashes('success') %}
                    <div class="bg-green-100 border border-green-400 text-green-700 px-5 py-4 rounded-xl">
                        <i class="fas fa-check-circle mr-2"></i> {{ message }}
                    </div>
                {% endfor %}

                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    
                    {# Même contenu que new.html.twig #}
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                {{ form_label(form.antecedentsMedicaux) }}
                            </label>
                            {{ form_widget(form.antecedentsMedicaux) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(form.antecedentsMedicaux) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                {{ form_label(form.maladiesChroniques) }}
                            </label>
                            {{ form_widget(form.maladiesChroniques) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(form.maladiesChroniques) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                {{ form_label(form.allergies) }}
                            </label>
                            {{ form_widget(form.allergies) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(form.allergies) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                {{ form_label(form.traitementsEnCours) }}
                            </label>
                            {{ form_widget(form.traitementsEnCours) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(form.traitementsEnCours) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                {{ form_label(form.diagnostics) }}
                            </label>
                            {{ form_widget(form.diagnostics) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(form.diagnostics) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                {{ form_label(form.notesMedecin) }}
                            </label>
                            {{ form_widget(form.notesMedecin) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(form.notesMedecin) }}</div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    {{ form_label(form.objectifSante) }}
                                </label>
                                {{ form_widget(form.objectifSante) }}
                                <div class="text-red-600 text-sm mt-1">{{ form_errors(form.objectifSante) }}</div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">
                                    {{ form_label(form.niveauActivite) }}
                                </label>
                                {{ form_widget(form.niveauActivite) }}
                                <div class="text-red-600 text-sm mt-1">{{ form_errors(form.niveauActivite) }}</div>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-3 mt-8 pt-6 border-t border-gray-200">
                        <button type="submit" 
                                class="flex-1 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition">
                            <i class="fas fa-save mr-2"></i>
                            Mettre à jour
                        </button>
                        <a href="{{ path('dossier_medical_index') }}"
                           class="px-6 py-3 bg-gray-200 text-gray-700 font-semibold rounded-lg hover:bg-gray-300 transition">
                            Annuler
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>

            </div>
        </main>
    </div>
</div>
{% endblock %}