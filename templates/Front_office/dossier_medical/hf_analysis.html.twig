{% extends 'base.html.twig' %}

{% block title %}Analyse Hugging Face — Dossier #{{ dossier_medical.id }}{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-gray-50">
    {% include 'components/sidebar.html.twig' %}

    <div class="flex flex-1 flex-col lg:ml-72">
        {% include 'components/top-nav.html.twig' %}

        <main class="flex-1 overflow-auto pb-12">
            <div class="mx-auto max-w-5xl space-y-6 p-4 lg:p-8">

                {# ══════════════════════════════════════
                   HEADER
                ══════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    {# Barre orange top #}
                    <div class="h-1 w-full bg-gradient-to-r from-orange-400 via-orange-500 to-cyan-500"></div>
                    <div class="p-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                        <div>
                            {# Badges #}
                            <div class="flex flex-wrap gap-2 mb-3">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-orange-50 text-orange-600 text-xs font-bold rounded-full border border-orange-200">
                                    🤗 API EXTERNE — Hugging Face
                                </span>
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-cyan-50 text-cyan-700 text-xs font-bold rounded-full border border-cyan-200">
                                    IA 2 / 2
                                </span>
                                {% if api_key_valide %}
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 text-green-700 text-xs font-bold rounded-full border border-green-200">
                                        ✅ Clé API active
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-red-50 text-red-600 text-xs font-bold rounded-full border border-red-200">
                                        ❌ Clé manquante
                                    </span>
                                {% endif %}
                            </div>
                            {# Titre #}
                            <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
                                🤗 Analyse Hugging Face
                                <span class="text-orange-500">— Classification Médicale Zéro-Shot</span>
                            </h1>
                            <p class="text-sm text-gray-500 mt-1">
                                Modèle :
                                <span class="font-semibold text-cyan-600">{{ model_name|default('typeform/distilbert-base-uncased-mnli') }}</span>
                                &nbsp;·&nbsp; Dossier
                                <span class="font-semibold text-orange-500">#{{ dossier_medical.id }}</span>
                            </p>
                        </div>
                        {# Boutons nav #}
                        <div class="flex flex-col gap-2 flex-shrink-0">
                            <a href="{{ path('dossier_medical_ai_analysis', {'id': dossier_medical.id}) }}"
                               class="inline-flex items-center gap-2 px-4 py-2 bg-purple-600 text-white text-sm font-semibold rounded-xl hover:bg-purple-700 transition shadow-sm">
                                🤖 Analyse Groq (IA 1)
                            </a>
                            <a href="{{ path('dossier_medical_show', {'id': dossier_medical.id}) }}"
                               class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-600 text-sm font-semibold rounded-xl hover:bg-gray-200 transition">
                                <i class="fas fa-arrow-left text-xs"></i> Retour au dossier
                            </a>
                        </div>
                    </div>
                </div>

                {# ══════════════════════════════════════
                   DONNÉES ANALYSÉES
                ══════════════════════════════════════ #}
                {% if texte_analyse %}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-8 h-8 bg-cyan-100 rounded-lg flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-file-medical text-cyan-600 text-sm"></i>
                        </div>
                        <h2 class="text-base font-bold text-gray-900">Données médicales envoyées à l'API Hugging Face</h2>
                    </div>
                    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 border-l-4 border-l-cyan-400">
                        <p class="text-sm text-gray-700 leading-relaxed italic">
                            "{{ texte_analyse }}"
                        </p>
                    </div>
                    <div class="flex flex-wrap gap-3 mt-3">
                        <span class="inline-flex items-center gap-1 px-3 py-1 bg-gray-100 text-gray-500 text-xs rounded-lg font-mono">
                            {{ texte_analyse|length }} caractères
                        </span>
                        <span class="inline-flex items-center gap-1 px-3 py-1 bg-cyan-50 text-cyan-600 text-xs rounded-lg font-mono">
                            → POST api-inference.huggingface.co/models/{{ model_name }}
                        </span>
                    </div>
                </div>
                {% endif %}

                {# ══════════════════════════════════════
                   ERREUR / DIAGNOSTIC
                ══════════════════════════════════════ #}
                {% if hf_error %}
                <div class="bg-white rounded-2xl border border-red-200 shadow-sm overflow-hidden">
                    <div class="bg-red-50 px-6 py-4 border-b border-red-100 flex items-center gap-3">
                        <div class="w-9 h-9 bg-red-100 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-exclamation-triangle text-red-500"></i>
                        </div>
                        <div>
                            <h2 class="text-base font-bold text-red-800">Diagnostic de l'erreur</h2>
                            {% if http_code %}
                                <span class="text-xs font-mono text-red-500">Code HTTP : {{ http_code }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="p-6 space-y-4">
                        <div class="flex items-start gap-3 p-4 bg-red-50 rounded-xl border border-red-100">
                            <span class="text-2xl">⚠️</span>
                            <p class="text-sm font-semibold text-red-700">{{ hf_error }}</p>
                        </div>

                        {# Solution selon code erreur #}
                        {% if http_code == 503 %}
                        <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-xl">
                            <p class="text-sm font-bold text-yellow-800 mb-2">⏳ Modèle en cours de démarrage</p>
                            <p class="text-sm text-yellow-700 mb-3">Le modèle Hugging Face démarre sur leurs serveurs. Attendez 20 secondes puis réessayez.</p>
                            <button onclick="location.reload()"
                                    class="inline-flex items-center gap-2 px-4 py-2 bg-yellow-500 text-white text-sm font-semibold rounded-xl hover:bg-yellow-600 transition">
                                <i class="fas fa-sync-alt"></i> Réessayer
                            </button>
                        </div>
                        {% endif %}

                        {% if not api_key_valide or http_code == 401 or http_code == 403 %}
                        <div class="p-4 bg-blue-50 border border-blue-200 rounded-xl">
                            <p class="text-sm font-bold text-blue-800 mb-3">🔑 Configuration de la clé API</p>
                            <div class="bg-gray-800 rounded-xl p-4 font-mono text-xs space-y-1">
                                <p class="text-gray-400"># Dans votre fichier .env :</p>
                                <p class="text-green-400">HUGGINGFACE_API_KEY=<span class="text-yellow-300">hf_xxxxxxxxxxxxxxxxxxxx</span></p>
                            </div>
                            <a href="https://huggingface.co/settings/tokens" target="_blank"
                               class="inline-flex items-center gap-1 mt-3 text-sm text-blue-600 font-semibold hover:underline">
                                <i class="fas fa-external-link-alt text-xs"></i>
                                Obtenir une clé gratuite sur huggingface.co
                            </a>
                        </div>
                        {% endif %}

                        {% if http_code == 410 %}
                        <div class="p-4 bg-orange-50 border border-orange-200 rounded-xl">
                            <p class="text-sm font-bold text-orange-800 mb-3">🔄 Modèle obsolète — Alternatives</p>
                            <div class="space-y-2">
                                {% for m in ['typeform/distilbert-base-uncased-mnli', 'MoritzLaurer/deberta-v3-large-zeroshot-v1', 'facebook/bart-large-mnli'] %}
                                <div class="flex items-center gap-2 p-3 bg-white border border-orange-200 rounded-lg">
                                    <i class="fas fa-check-circle text-green-500 text-xs"></i>
                                    <span class="text-sm font-mono text-gray-700">{{ m }}</span>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

                {# ══════════════════════════════════════
                   SCORES DE CLASSIFICATION
                ══════════════════════════════════════ #}
                {% if hf_result %}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
                        <div class="w-9 h-9 bg-orange-100 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-chart-bar text-orange-500"></i>
                        </div>
                        <div>
                            <h2 class="text-base font-bold text-gray-900">
                                Scores de Classification Médicale
                            </h2>
                            <p class="text-xs text-gray-500">
                                Modèle <span class="font-semibold text-orange-500">{{ model_name }}</span> — {{ hf_result|length }} catégories analysées
                            </p>
                        </div>
                    </div>
                    <div class="p-6 space-y-4" id="scores-container">
                        {% set idx = 0 %}
                        {% for label, score in hf_result %}
                            {% set pct = (score * 100)|round(1) %}

                            {% if pct > 35 %}
                                {% set barColor = 'bg-red-500' %}
                                {% set textColor = 'text-red-600' %}
                                {% set bgCard = 'bg-red-50 border-red-200' %}
                                {% set icon = '🚨' %}
                                {% set labelColor = 'text-red-700' %}
                            {% elseif pct > 18 %}
                                {% set barColor = 'bg-orange-400' %}
                                {% set textColor = 'text-orange-500' %}
                                {% set bgCard = 'bg-orange-50 border-orange-200' %}
                                {% set icon = '⚠️' %}
                                {% set labelColor = 'text-orange-700' %}
                            {% else %}
                                {% set barColor = 'bg-green-400' %}
                                {% set textColor = 'text-green-600' %}
                                {% set bgCard = 'bg-green-50 border-green-200' %}
                                {% set icon = '✅' %}
                                {% set labelColor = 'text-green-700' %}
                            {% endif %}

                            <div class="rounded-xl border p-4 transition-all hover:shadow-md
                                {{ idx == 0 ? 'bg-orange-50 border-orange-300 ring-2 ring-orange-200' : bgCard }}">

                                {% if idx == 0 %}
                                <div class="mb-2">
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-orange-500 text-white text-xs font-bold rounded-full">
                                        ⚡ Risque dominant
                                    </span>
                                </div>
                                {% endif %}

                                <div class="flex items-center justify-between mb-3 gap-2 flex-wrap">
                                    <div class="flex items-center gap-2">
                                        <span class="text-lg">{{ icon }}</span>
                                        <span class="text-sm font-bold {{ idx == 0 ? 'text-orange-800' : labelColor }}">
                                            {{ label }}
                                        </span>
                                    </div>
                                    <span class="text-2xl font-bold font-mono {{ idx == 0 ? 'text-orange-600' : textColor }}">
                                        {{ pct }}%
                                    </span>
                                </div>

                                {# Barre de progression #}
                                <div class="w-full bg-gray-200 rounded-full h-3 overflow-hidden">
                                    <div class="h-3 rounded-full transition-all duration-1000 ease-out {{ idx == 0 ? 'bg-orange-500' : barColor }}"
                                         style="width: 0%"
                                         data-target="{{ pct }}">
                                    </div>
                                </div>
                                <p class="text-xs text-gray-400 mt-1.5 font-mono">
                                    Score de confiance : {{ pct }} / 100
                                </p>
                            </div>
                            {% set idx = idx + 1 %}
                        {% endfor %}
                    </div>
                </div>

                {# ══════════════════════════════════════
                   INTERPRÉTATION CLINIQUE
                ══════════════════════════════════════ #}
                {% set topLabel = hf_result|keys|first %}
                {% set topScore = hf_result|first %}
                {% set topPct = (topScore * 100)|round(1) %}

                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
                        <div class="w-9 h-9 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-lightbulb text-blue-500"></i>
                        </div>
                        <h2 class="text-base font-bold text-gray-900">Interprétation Clinique</h2>
                    </div>
                    <div class="p-6">
                        <div class="rounded-xl border p-6
                            {% if topPct > 35 %}bg-red-50 border-red-200
                            {% elseif topPct > 18 %}bg-orange-50 border-orange-200
                            {% else %}bg-green-50 border-green-200{% endif %}">

                            <div class="flex items-start gap-5 flex-wrap">
                                {# Icone statut #}
                                <div class="text-6xl">
                                    {{ topPct > 35 ? '🚨' : (topPct > 18 ? '⚠️' : '✅') }}
                                </div>
                                <div class="flex-1 min-w-52">
                                    <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-1">
                                        Catégorie dominante
                                    </p>
                                    <p class="text-lg font-bold text-gray-900 mb-1 leading-tight">
                                        {{ topLabel }}
                                    </p>
                                    <p class="text-3xl font-bold font-mono mb-3
                                        {{ topPct > 35 ? 'text-red-600' : (topPct > 18 ? 'text-orange-500' : 'text-green-600') }}">
                                        {{ topPct }}%
                                        <span class="text-sm font-normal text-gray-400">de confiance</span>
                                    </p>
                                    <div class="border-l-4 pl-4
                                        {{ topPct > 35 ? 'border-red-400' : (topPct > 18 ? 'border-orange-400' : 'border-green-400') }}">
                                        <p class="text-sm text-gray-700 leading-relaxed">
                                            {% if topPct > 35 %}
                                                <strong class="text-red-700">Attention :</strong>
                                                Le modèle IA détecte une condition nécessitant une attention médicale prioritaire.
                                                Une consultation rapide est fortement recommandée.
                                                Consultez l'analyse Groq pour les médecins spécialistes suggérés.
                                            {% elseif topPct > 18 %}
                                                <strong class="text-orange-700">Suivi recommandé :</strong>
                                                Le modèle suggère un suivi médical régulier.
                                                Consultez un spécialiste dans les prochaines semaines pour une évaluation approfondie.
                                            {% else %}
                                                <strong class="text-green-700">Condition stable :</strong>
                                                Le modèle indique une condition relativement stable.
                                                Continuez les traitements prescrits et maintenez un suivi médical régulier.
                                            {% endif %}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Boutons d'action #}
                        <div class="flex flex-wrap gap-3 mt-5">
                            <a href="{{ path('dossier_medical_ai_analysis', {'id': dossier_medical.id}) }}"
                               class="inline-flex items-center gap-2 px-5 py-2.5 bg-purple-600 text-white text-sm font-semibold rounded-xl hover:bg-purple-700 transition shadow-sm">
                                🤖 Analyse Groq complète (IA 1)
                            </a>
                            <a href="{{ path('dossier_medical_export_pdf', {'id': dossier_medical.id}) }}"
                               class="inline-flex items-center gap-2 px-5 py-2.5 bg-red-600 text-white text-sm font-semibold rounded-xl hover:bg-red-700 transition shadow-sm">
                                <i class="fas fa-file-pdf"></i> Export PDF
                            </a>
                            <a href="{{ path('dossier_medical_send_email', {'id': dossier_medical.id}) }}"
                               class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition shadow-sm">
                                <i class="fas fa-envelope"></i> Envoyer email
                            </a>
                            <a href="{{ path('dossier_medical_index') }}"
                               class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 text-gray-600 text-sm font-semibold rounded-xl hover:bg-gray-200 transition">
                                <i class="fas fa-arrow-left text-xs"></i> Mes dossiers
                            </a>
                        </div>
                    </div>
                </div>
                {% endif %}

                {# ══════════════════════════════════════
                   COMPARAISON DOUBLE IA — Pour le prof
                ══════════════════════════════════════ #}
                <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
                        <div class="w-9 h-9 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-robot text-purple-500"></i>
                        </div>
                        <div>
                            <h2 class="text-base font-bold text-gray-900">Architecture Double IA</h2>
                            <p class="text-xs text-gray-500">Deux modèles complémentaires pour une analyse médicale complète</p>
                        </div>
                    </div>
                    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">

                        {# IA 1 Groq #}
                        <div class="rounded-xl border border-purple-200 bg-purple-50 p-5">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 bg-purple-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <span class="text-lg">🤖</span>
                                </div>
                                <div>
                                    <p class="font-bold text-purple-900 text-sm">IA 1 — Groq (LLaMA 3.3-70b)</p>
                                    <span class="inline-flex items-center px-2 py-0.5 bg-purple-200 text-purple-700 text-xs font-bold rounded-full">
                                        API EXTERNE
                                    </span>
                                </div>
                            </div>
                            <ul class="space-y-2">
                                {% for item in ['Score santé global /100', 'Analyse textuelle riche et contextuelle', 'Recommandations personnalisées', 'Médecins et hôpitaux suggérés', 'Plan de suivi médical détaillé'] %}
                                <li class="flex items-start gap-2 text-sm text-purple-800">
                                    <i class="fas fa-check-circle text-purple-500 mt-0.5 flex-shrink-0 text-xs"></i>
                                    {{ item }}
                                </li>
                                {% endfor %}
                            </ul>
                        </div>

                        {# IA 2 HF #}
                        <div class="rounded-xl border border-orange-200 bg-orange-50 p-5">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 bg-orange-500 rounded-xl flex items-center justify-center flex-shrink-0">
                                    <span class="text-lg">🤗</span>
                                </div>
                                <div>
                                    <p class="font-bold text-orange-900 text-sm">IA 2 — Hugging Face (NLI)</p>
                                    <span class="inline-flex items-center px-2 py-0.5 bg-orange-200 text-orange-700 text-xs font-bold rounded-full">
                                        API EXTERNE
                                    </span>
                                </div>
                            </div>
                            <ul class="space-y-2">
                                {% for item in ['Classification zero-shot médicale', 'Scores de confiance par catégorie', 'Détection multi-risques', 'Modèle NLI pré-entraîné', 'Analyse complémentaire à Groq'] %}
                                <li class="flex items-start gap-2 text-sm text-orange-800">
                                    <i class="fas fa-check-circle text-orange-500 mt-0.5 flex-shrink-0 text-xs"></i>
                                    {{ item }}
                                </li>
                                {% endfor %}
                            </ul>
                        </div>

                    </div>
                    {# Note pour le prof #}
                    <div class="px-6 pb-5">
                        <div class="flex items-center gap-2 p-3 bg-blue-50 border border-blue-200 rounded-xl">
                            <i class="fas fa-graduation-cap text-blue-500 flex-shrink-0"></i>
                            <p class="text-xs text-blue-700 font-medium">
                                Les deux modèles IA travaillent de manière complémentaire :
                                <strong>Groq</strong> analyse en profondeur, <strong>Hugging Face</strong> classifie avec des scores de confiance.
                            </p>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>
</div>

<style>
@keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
}
.mx-auto > * {
    animation: fadeSlideUp 0.5s ease forwards;
}
.mx-auto > *:nth-child(1) { animation-delay: 0.05s; }
.mx-auto > *:nth-child(2) { animation-delay: 0.12s; }
.mx-auto > *:nth-child(3) { animation-delay: 0.20s; }
.mx-auto > *:nth-child(4) { animation-delay: 0.28s; }
.mx-auto > *:nth-child(5) { animation-delay: 0.36s; }
.mx-auto > *:nth-child(6) { animation-delay: 0.44s; }
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const bars = document.querySelectorAll('[data-target]');
    setTimeout(() => {
        bars.forEach((bar, i) => {
            setTimeout(() => {
                bar.style.width = bar.dataset.target + '%';
            }, 300 + i * 120);
        });
    }, 200);
});
</script>
{% endblock %}
