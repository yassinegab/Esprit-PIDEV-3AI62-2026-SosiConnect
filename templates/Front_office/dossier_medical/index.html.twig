{% extends 'base.html.twig' %}

{% block title %}Mes Dossiers Médicaux{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-gray-50">
    {% include 'components/sidebar.html.twig' %}

    <div class="flex flex-1 flex-col lg:ml-72">
        {% include 'components/top-nav.html.twig' %}

        <main class="flex-1 overflow-auto pb-12">
            <div class="mx-auto max-w-7xl space-y-8 p-4 lg:p-8">

                {# Header #}
                <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900">
                            <i class="fas fa-file-medical text-green-600 mr-3"></i>
                            Mes Dossiers Médicaux
                        </h1>
                        <p class="text-gray-600 mt-1">
                            Gérez vos informations médicales
                        </p>
                    </div>
                    <div class="flex gap-3">
                        <a href="{{ path('dossier_medical_new') }}"
                           class="inline-flex items-center px-5 py-2.5 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition shadow-md">
                            <i class="fas fa-plus mr-2"></i> Nouveau Dossier
                        </a>
                        <a href="{{ path('app_service_home') }}"
                           class="inline-flex items-center px-5 py-2.5 bg-gray-200 text-gray-700 font-semibold rounded-lg hover:bg-gray-300 transition">
                            <i class="fas fa-arrow-left mr-2"></i> Retour
                        </a>
                    </div>
                </div>

                {# Messages flash #}
                {% for message in app.flashes('success') %}
                    <div class="bg-green-100 border border-green-400 text-green-700 px-5 py-4 rounded-xl">
                        <i class="fas fa-check-circle mr-2"></i> {{ message }}
                    </div>
                {% endfor %}

                {# Liste des dossiers #}
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    {% if dossiers is empty %}
                        <div class="p-16 text-center">
                            <i class="fas fa-folder-open text-gray-300 text-7xl mb-6"></i>
                            <h3 class="text-xl font-bold text-gray-900 mb-2">Aucun dossier médical</h3>
                            <p class="text-gray-600 mb-6">Créez votre premier dossier médical pour commencer</p>
                            <a href="{{ path('dossier_medical_new') }}"
                               class="inline-flex items-center px-6 py-3 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700">
                                <i class="fas fa-plus mr-2"></i> Créer mon dossier
                            </a>
                        </div>
                    {% else %}
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">ID</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date de création</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Dernière MAJ</th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Objectif</th>
                                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    {% for dossier in dossiers %}
                                        <tr class="hover:bg-gray-50 transition-colors">
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                                #{{ dossier.id }}
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                                {{ dossier.dateCreation|date('d/m/Y H:i') }}
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                                {{ dossier.derniereMiseAJour|date('d/m/Y H:i') }}
                                            </td>
                                            <td class="px-6 py-4 text-sm text-gray-600">
                                                {{ dossier.objectifSante ?? 'Non défini' }}
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
                                                <a href="{{ path('dossier_medical_show', {'id': dossier.id}) }}"
                                                   class="text-blue-600 hover:text-blue-900">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="{{ path('dossier_medical_edit', {'id': dossier.id}) }}"
                                                   class="text-green-600 hover:text-green-900">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button onclick="confirmDelete({{ dossier.id }})"
                                                        class="text-red-600 hover:text-red-900">
                                                    <i class="fas fa-trash"></i>
                                                </button>

                                                <form id="delete-form-{{ dossier.id }}"
                                                      method="post"
                                                      action="{{ path('dossier_medical_delete', {'id': dossier.id}) }}"
                                                      style="display: none;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dossier.id) }}">
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>

            </div>
        </main>
    </div>
</div>

<script>
function confirmDelete(id) {
    if (confirm('Voulez-vous vraiment supprimer ce dossier médical ?')) {
        document.getElementById('delete-form-' + id).submit();
    }
}
</script>
{% endblock %}