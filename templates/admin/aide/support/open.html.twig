{% extends 'admin/layout.html.twig' %}

{% block title %}Tickets Ouverts - Support{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.ticket-card {
    transition: all 0.3s ease;
}
.ticket-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}
.priority-critical { border-left: 4px solid #dc2626; }
.priority-high { border-left: 4px solid #f97316; }
.priority-medium { border-left: 4px solid #eab308; }
.priority-low { border-left: 4px solid #22c55e; }
.avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
}
</style>
{% endblock %}

{% block content %}
<div class="space-y-6 animate-fadeIn">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-red-500 to-orange-500 rounded-xl flex items-center justify-center text-white text-xl relative">
                    🚨
                    <span class="absolute -top-1 -right-1 flex h-4 w-4">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500"></span>
                    </span>
                </div>
                Tickets Ouverts
            </h1>
            <p class="text-gray-500 mt-1 ml-16">Tickets nécessitant une attention immédiate</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('admin_support') }}" 
               class="px-5 py-3 bg-gray-100 text-gray-700 rounded-xl font-semibold hover:bg-gray-200 transition flex items-center gap-2">
                ← Tous les tickets
            </a>
        </div>
    </div>

    <div class="bg-gradient-to-r from-red-500 to-orange-500 rounded-2xl p-6 text-white">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-3xl">
                    ⚡
                </div>
                <div>
                    <h3 class="font-bold text-lg">Action Requise</h3>
                    <p class="text-red-100 text-sm">{{ tickets|length }} tickets en attente de traitement</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-3xl font-bold">{{ tickets|length }}</p>
                <p class="text-red-100 text-sm">Tickets ouverts</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4">
        {% for ticket in tickets %}
        <a href="{{ path('admin_support_view', {id: ticket.id}) }}" 
           class="ticket-card bg-white rounded-2xl shadow-lg border border-gray-100 p-5 block hover:border-red-200
                  {% if ticket.priority == 'critical' %}priority-critical
                  {% elseif ticket.priority == 'high' %}priority-high
                  {% elseif ticket.priority == 'medium' %}priority-medium
                  {% else %}priority-low{% endif %}">
            <div class="flex items-start justify-between gap-4">
                <div class="flex items-start gap-4 flex-1">
                    <div class="avatar bg-gradient-to-br from-red-400 to-orange-500 text-white flex-shrink-0">
                        {{ ticket.userName|first|upper }}
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-1">
                            <h3 class="font-bold text-gray-800 truncate">{{ ticket.subject }}</h3>
                            {% if ticket.priority == 'critical' %}
                            <span class="px-2 py-0.5 text-xs rounded-full bg-red-100 text-red-700 font-semibold flex-shrink-0 animate-pulse">
                                CRITIQUE
                            </span>
                            {% elseif ticket.priority == 'high' %}
                            <span class="px-2 py-0.5 text-xs rounded-full bg-orange-100 text-orange-700 font-semibold flex-shrink-0">
                                HAUTE
                            </span>
                            {% else %}
                            <span class="px-2 py-0.5 text-xs rounded-full bg-yellow-100 text-yellow-700 font-semibold flex-shrink-0">
                                {{ ticket.priority|upper }}
                            </span>
                            {% endif %}
                        </div>
                        <p class="text-gray-500 text-sm truncate mb-2">{{ ticket.description[:100] }}...</p>
                        <div class="flex items-center gap-4 text-xs text-gray-400">
                            <span class="flex items-center gap-1">
                                <span>👤</span> {{ ticket.userName }}
                            </span>
                            <span class="flex items-center gap-1">
                                <span>📧</span> {{ ticket.userEmail }}
                            </span>
                            <span class="flex items-center gap-1">
                                <span>📁</span> {{ ticket.category }}
                            </span>
                            <span class="flex items-center gap-1">
                                <span>🕐</span> {{ ticket.createdAt|date('d/m/Y à H:i') }}
                            </span>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col items-end gap-2 flex-shrink-0">
                    <span class="px-3 py-1.5 rounded-full text-sm font-semibold 
                        {% if ticket.status == 'open' %}bg-green-100 text-green-700
                        {% else %}bg-yellow-100 text-yellow-700{% endif %}">
                        {% if ticket.status == 'open' %}🟢 Ouvert
                        {% else %}🟡 En cours{% endif %}
                    </span>
                    <span class="text-xs text-gray-400">
                        #{{ ticket.id }}
                    </span>
                </div>
            </div>
        </a>
        {% else %}
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-16 text-center">
            <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center text-5xl mx-auto mb-4">
                ✅
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Excellent !</h3>
            <p class="text-gray-500">Aucun ticket ouvert en attente de traitement</p>
            <a href="{{ path('admin_support') }}" class="inline-block mt-4 px-6 py-3 bg-blue-500 text-white rounded-xl font-semibold hover:bg-blue-600 transition">
                Voir tous les tickets
            </a>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
