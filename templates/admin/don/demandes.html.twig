{% extends 'admin/layout.html.twig' %}

{% block title %}Gestion des demandes{% endblock %}

{% block content %}
<div class="space-y-6 animate-fadeIn">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-purple-700 flex items-center gap-2">
            <span class="text-3xl">📥</span> Gestion des demandes
        </h1>
        <span class="bg-gray-100 px-3 py-1 rounded-full text-sm text-gray-600">
            {{ pagination.total }} demande(s)
        </span>
    </div>

    {% for message in app.flashes('success') %}
    <div class="bg-green-100 border-l-4 border-green-500 text-green-700 px-4 py-3 rounded-lg shadow">
        ✅ {{ message }}
    </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
    <div class="bg-red-100 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded-lg shadow">
        ❌ {{ message }}
    </div>
    {% endfor %}

    <div class="bg-white p-4 rounded-xl shadow">
        <form method="get" class="flex flex-wrap gap-3 items-end">
            <div class="flex-1 min-w-[200px]">
                <input type="text" name="search" value="{{ filters.search|default('') }}"
                       placeholder="🔍 Rechercher par région..."
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-purple-500">
            </div>
            <div>
                <select name="type" class="border border-gray-300 rounded-lg px-3 py-2">
                    <option value="">Tous types</option>
                    <option value="sang" {{ filters.type == 'sang' ? 'selected' }}>Sang</option>
                    <option value="organe" {{ filters.type == 'organe' ? 'selected' }}>Organe</option>
                </select>
            </div>
            <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg transition">
                Filtrer
            </button>
            <a href="{{ path('admin_demandes') }}" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded-lg transition">
                Reset
            </a>
        </form>
    </div>

    <div class="space-y-4">
        {% for demande in demandes %}
        <div class="bg-white p-5 rounded-xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div class="flex items-start gap-4">
                    <div class="text-4xl">
                        {{ demande.typeDemande == 'sang' ? '🩸' : '🫀' }}
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                            <span class="font-bold text-lg text-gray-800">{{ demande.typeDemande|upper }}</span>
                            {% if demande.typeSanguin %}
                                <span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-xs font-bold">{{ demande.typeSanguin }}</span>
                            {% elseif demande.typeOrgane %}
                                <span class="bg-purple-100 text-purple-700 px-2 py-0.5 rounded text-xs">{{ demande.typeOrgane }}</span>
                            {% endif %}
                            {% if demande.urgence %}
                                <span class="bg-orange-100 text-orange-700 px-2 py-0.5 rounded text-xs font-bold animate-pulse">URGENT</span>
                            {% endif %}
                        </div>
                        <div class="text-sm text-gray-500 flex items-center gap-4">
                            <span>📍 {{ demande.region }}</span>
                            <span>📅 {{ demande.dateDemande|date('d/m/Y H:i') }}</span>
                            {% if demande.rangAttente %}
                            <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs">
                                Rang: {{ demande.rangAttente }}
                            </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <div class="flex gap-2">
                    <form method="post" action="{{ path('admin_demande_approve', {id: demande.id}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ demande.id) }}">
                        <button type="submit" 
                                class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition text-sm font-medium flex items-center gap-1">
                            ✅ Approuver
                        </button>
                    </form>
                    
                    <form method="post" action="{{ path('admin_demande_delete', {id: demande.id}) }}" 
                          class="inline" onsubmit="return confirm('Supprimer cette demande ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ demande.id) }}">
                        <button type="submit" 
                                class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition text-sm font-medium">
                            🗑 Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% else %}
        <div class="bg-white p-12 rounded-xl shadow text-center text-gray-500">
            <div class="text-4xl mb-2">📭</div>
            <p>Aucune demande trouvée</p>
        </div>
        {% endfor %}
    </div>

    {% if pagination.pages > 1 %}
    <div class="bg-white p-4 rounded-xl shadow flex justify-center items-center gap-4">
        {% if pagination.current > 1 %}
        <a href="{{ path('admin_demandes', app.request.query.all|merge({page: pagination.current - 1})) }}" 
           class="px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg transition">
            ← Précédent
        </a>
        {% endif %}
        
        <span class="text-sm text-gray-600 px-3">
            Page {{ pagination.current }} / {{ pagination.pages }}
        </span>
        
        {% if pagination.current < pagination.pages %}
        <a href="{{ path('admin_demandes', app.request.query.all|merge({page: pagination.current + 1})) }}" 
           class="px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-lg transition">
            Suivant →
        </a>
        {% endif %}
    </div>
    {% endif %}
</div>
{% endblock %}
