{% extends 'base.html.twig' %}

{% block title %}ChatWell - AI Mental Health Assistant{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/ai-assistant.css') }}">
{% endblock %}

{% block body %}
<div class="flex flex-1 flex-col h-screen">
    {% include 'components/top-nav.html.twig' %}
    
    <div class="main-container ai-assistant-wrapper flex-1 overflow-hidden relative">
    <div class="row g-0 h-100">
        <div class="col-lg-5 col-md-6 p-3">
            <div class="video-panel">
                <div class="video-container" id="videoContainer">
                    <video id="videoPreview" autoplay playsinline muted></video>
                    <div class="avatar-placeholder" id="avatarPlaceholder">
                        <div class="robot-avatar">
                            <div class="robot-head">
                                <div class="robot-eyes">
                                    <div class="eye left"></div>
                                    <div class="eye right"></div>
                                </div>
                                <div class="robot-mouth"></div>
                            </div>
                            <div class="robot-body"></div>
                        </div>
                    </div>
                    <div class="status-indicator" id="statusIndicator">
                        <span class="status-dot"></span>
                        <span class="status-text">Camera Off</span>
                    </div>
                </div>
                
                <div class="controls-container">
                    <button class="btn btn-control" id="cameraBtn" title="Toggle Camera">
                        <i class="fas fa-video"></i>
                    </button>
                    <button class="btn btn-control" id="micBtn" title="Toggle Microphone">
                        <i class="fas fa-microphone"></i>
                    </button>
                    <button class="btn btn-record" id="recordBtn" title="Start Recording">
                        <i class="fas fa-microphone"></i>
                    </button>
                </div>

                <div class="recording-status" id="recordingStatus">
                    <div class="waveform" id="waveform">
                        <span></span><span></span><span></span><span></span><span></span>
                    </div>
                    <span class="recording-text">Listening...</span>
                </div>
            </div>
        </div>

        <div class="col-lg-7 col-md-6 p-3">
            <div class="chat-panel">
                <div class="chat-header">
                    <h5 class="mb-0">
                        <i class="fas fa-comments me-2"></i>
                        Talk to your AI Coach
                    </h5>
                </div>
                
                <div class="chat-messages" id="chatMessages">
                    <div class="message assistant">
                        <div class="message-content">
                            <p>Hello! I'm your AI Mental Wellness Coach. I'm here to listen and support you.</p>
                            <p>You can:</p>
                            <ul>
                                <li>Click the microphone button and speak to me</li>
                                <li>Type your message in the chat</li>
                                <li>Share what's on your mind</li>
                            </ul>
                            <p>How are you feeling today?</p>
                        </div>
                        <div class="message-time">{{ 'now'|date('g:i A') }}</div>
                    </div>
                </div>

                <div class="chat-input-container">
                    <input type="text" class="form-control" id="chatInput" placeholder="Type your message...">
                    <button class="btn btn-primary" id="sendBtn">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>

                <div class="emotion-indicator" id="emotionIndicator">
                    <span class="emotion-label">Current mood:</span>
                    <span class="emotion-value" id="currentEmotion">-</span>
                    <span class="stress-label">Stress:</span>
                    <span class="stress-value" id="currentStress">-</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="loading-overlay" id="loadingOverlay">
    <div class="spinner-container">
        <div class="spinner"></div>
        <p class="mt-3">Processing...</p>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="{{ asset('js/ai-assistant.js') }}"></script>
{% endblock %}
