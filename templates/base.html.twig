<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Cycle{% endblock %}</title>

    <!-- Tailwind -->
    <link rel="stylesheet" href="{{ asset('build/tailwind.css') }}">
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/main.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-background text-foreground">

    {# flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 mb-4 rounded {{ label == 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}

    <!-- Alpine.js -->
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

    {% block javascripts %}
    <script>
document.addEventListener("mousemove", function(e) {
  document.querySelectorAll(".magic-bento-card").forEach(card => {
    const rect = card.getBoundingClientRect();
    const x = ((e.clientX - rect.left) / rect.width) * 100;
    const y = ((e.clientY - rect.top) / rect.height) * 100;

    const distance = Math.hypot(
      e.clientX - (rect.left + rect.width / 2),
      e.clientY - (rect.top + rect.height / 2)
    );

    let intensity = 0;
    if (distance < 300) {
      intensity = 1 - distance / 300;
    }

    card.style.setProperty("--glow-x", x + "%");
    card.style.setProperty("--glow-y", y + "%");
    card.style.setProperty("--glow-intensity", intensity);
  });
});
</script>
{% endblock %}
</body>
</html>

