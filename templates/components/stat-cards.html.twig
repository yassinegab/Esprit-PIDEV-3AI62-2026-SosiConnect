<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 animate-fadeIn" style="animation-delay: 0.1s;">
    {# Health Score Card #}
    <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:shadow-md">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-gray-500">Score Santé</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">85<span class="text-sm font-normal text-gray-400">/100</span></p>
            </div>
            <div class="rounded-full bg-green-50 p-3 text-green-600">
                <i class="fas fa-heartbeat text-xl"></i>
            </div>
        </div>
        <div class="mt-4 flex items-center text-sm text-green-600">
            <i class="fas fa-arrow-up mr-1"></i>
            <span class="font-medium">2.5%</span>
            <span class="ml-2 text-gray-400">vs semaine dernière</span>
        </div>
    </div>

    {# Active Calories Card #}
    <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:shadow-md">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-gray-500">Calories Actives</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">1,240</p>
            </div>
            <div class="rounded-full bg-orange-50 p-3 text-orange-600">
                <i class="fas fa-fire text-xl"></i>
            </div>
        </div>
        <div class="mt-4 flex items-center text-sm text-orange-600">
            <i class="fas fa-arrow-up mr-1"></i>
            <span class="font-medium">12%</span>
            <span class="ml-2 text-gray-400">vs hier</span>
        </div>
    </div>

    {# Sleep Quality Card #}
    <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:shadow-md">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-gray-500">Sommeil</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">7h 20m</p>
            </div>
            <div class="rounded-full bg-indigo-50 p-3 text-indigo-600">
                <i class="fas fa-moon text-xl"></i>
            </div>
        </div>
        <div class="mt-4 flex items-center text-sm text-gray-400">
            <span class="font-medium text-indigo-600">Qualité: Bonne</span>
        </div>
    </div>

    {# Stress Level Card #}
    <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:shadow-md">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-sm font-medium text-gray-500">Niveau Stress</p>
                <p class="text-3xl font-bold text-gray-900 mt-2">Bas</p>
            </div>
            <div class="rounded-full bg-blue-50 p-3 text-blue-600">
                <i class="fas fa-brain text-xl"></i>
            </div>
        </div>
        <div class="mt-4 flex items-center text-sm text-blue-600">
            <i class="fas fa-arrow-down mr-1"></i>
            <span class="font-medium">5%</span>
            <span class="ml-2 text-gray-400">vs moyenne</span>
        </div>
    </div>
</div>
