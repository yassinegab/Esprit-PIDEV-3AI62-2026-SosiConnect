<!-- Voice Assistant Floating Widget -->
<div x-data="voiceAssistant()" 
     x-init="init()"
     class="fixed bottom-6 right-6 z-50">

    <!-- Response Modal -->
    <div x-show="showResponse" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 transform translate-y-4"
         x-transition:enter-end="opacity-100 transform translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 transform translate-y-0"
         x-transition:leave-end="opacity-0 transform translate-y-4"
         @click.away="showResponse = false"
         :class="urgenceDeclared ? 'w-96' : 'w-80'"
         class="absolute bottom-20 right-0 bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden">
        
        <!-- Header -->
        <div :class="urgenceDeclared ? 'bg-gradient-to-r from-red-600 to-red-700 animate-pulse' : 'bg-gradient-to-r from-purple-600 to-indigo-600'"
             class="px-4 py-3 flex items-center gap-3">
            <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center text-xl">
                <span x-text="urgenceDeclared ? '🚨' : '🤖'"></span>
            </div>
            <div>
                <p class="text-white font-semibold text-sm" x-text="urgenceDeclared ? 'URGENCE DÉCLARÉE' : 'Assistant Wellness'"></p>
                <p class="text-xs" :class="urgenceDeclared ? 'text-red-200' : 'text-purple-200'" x-text="urgenceDeclared ? 'Contacts notifiés' : 'En ligne'"></p>
            </div>
            <button @click="showResponse = false" class="ml-auto text-white/80 hover:text-white">
                ✕
            </button>
        </div>
        
        <!-- Content -->
        <div class="p-4">
            <p class="text-gray-800 text-sm leading-relaxed" x-text="responseText"></p>
            
            <!-- Emergency Details -->
            <div x-show="urgenceDeclared" class="mt-4 space-y-3">
                <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
                    <span class="text-sm text-green-700">📱 SMS envoyés</span>
                    <span class="font-bold text-green-700" x-text="smsSent"></span>
                </div>
                <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                    <span class="text-sm text-blue-700">📧 Emails envoyés</span>
                    <span class="font-bold text-blue-700" x-text="emailsSent"></span>
                </div>
                <div x-show="locationCaptured" class="flex items-center gap-2 text-xs text-gray-500">
                    <span>📍</span>
                    <span>Position capturée</span>
                </div>
            </div>
            
            <!-- Transcript -->
            <div x-show="transcriptText && !urgenceDeclared" class="mt-3 pt-3 border-t border-gray-100">
                <p class="text-xs text-gray-500 mb-1">Vous avez dit:</p>
                <p class="text-sm text-gray-700 italic" x-text="'\"' + transcriptText + '\"'"></p>
            </div>
        </div>
        
        <!-- Actions -->
        <div x-show="redirectUrl" class="px-4 pb-4">
            <a :href="redirectUrl" 
               :class="urgenceDeclared ? 'bg-red-600 hover:bg-red-700' : 'bg-purple-600 hover:bg-purple-700'"
               class="block text-center text-white py-2 rounded-lg text-sm font-medium transition">
                <span x-text="urgenceDeclared ? 'Voir les détails →' : 'Aller à la page →'"></span>
            </a>
        </div>
    </div>

    <!-- Main Button -->
    <button @click="toggleListening()"
            :class="isListening ? 'bg-red-500 hover:bg-red-600 scale-110' : 'bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700'"
            class="w-16 h-16 rounded-full text-white shadow-2xl transition-all duration-300 flex items-center justify-center relative group focus:outline-none focus:ring-4 focus:ring-purple-300">
        
        <!-- Icon -->
        <span class="text-2xl" x-text="isListening ? '⏹️' : '🎤'"></span>
        
        <!-- Pulse Animation -->
        <span x-show="isListening" 
              class="absolute inset-0 rounded-full bg-red-400 animate-ping opacity-75"></span>
        
        <!-- Tooltip -->
        <span class="absolute right-20 bg-gray-900 text-white text-xs px-3 py-2 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
            <span x-text="isListening ? 'Écoute...' : 'Assistant vocal'"></span>
            <span class="block text-gray-400 text-xs mt-1">Ctrl+Shift+V</span>
        </span>
    </button>

    <!-- Status Indicator -->
    <div x-show="isListening" 
         x-transition
         class="absolute -top-12 left-1/2 transform -translate-x-1/2 bg-white px-4 py-2 rounded-full shadow-lg flex items-center gap-2">
        <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
        <span class="text-sm text-gray-700">Je vous écoute...</span>
    </div>

    <!-- Quick Emergency Button (Optional) -->
    <button x-show="!isListening"
            @click="processCommand('urgence')"
            class="absolute -top-16 right-0 bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-full shadow-lg text-xs font-semibold transition flex items-center gap-2 group">
        <span class="text-base">🚨</span>
        <span class="group-hover:scale-110 transition">URGENCE</span>
    </button>
</div>

<!-- Voice Assistant Styles -->
<style>
@keyframes listening-pulse {
    0%, 100% { 
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
    }
    50% { 
        box-shadow: 0 0 0 20px rgba(239, 68, 68, 0);
    }
}

.voice-listening {
    animation: listening-pulse 1.5s infinite;
}

/* Emergency pulse animation */
@keyframes emergency-flash {
    0%, 100% { 
        box-shadow: 0 0 20px rgba(239, 68, 68, 0.8);
    }
    50% { 
        box-shadow: 0 0 40px rgba(239, 68, 68, 0.4);
    }
}

/* Speech recognition not supported message */
.voice-not-supported {
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
}

/* Emergency card styles */
.emergency-card {
    border: 2px solid #ef4444;
    animation: emergency-flash 1s infinite;
}
</style>

<!-- Voice Assistant Alpine.js Component -->
<script>
function voiceAssistant() {
    return {
        isListening: false,
        showResponse: false,
        responseText: '',
        transcriptText: '',
        redirectUrl: '',
        recognition: null,
        synthesis: window.speechSynthesis,
        urgenceDeclared: false,
        smsSent: 0,
        emailsSent: 0,
        locationCaptured: false,

        init() {
            // Check browser support
            if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
                console.warn('Speech recognition not supported');
                return;
            }

            // Initialize speech recognition
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            this.recognition = new SpeechRecognition();
            this.recognition.continuous = false;
            this.recognition.interimResults = false;
            this.recognition.lang = 'fr-FR';

            // On result
            this.recognition.onresult = (event) => {
                const text = event.results[0][0].transcript;
                this.transcriptText = text;
                this.processCommand(text);
            };

            // On end
            this.recognition.onend = () => {
                this.isListening = false;
            };

            // On error
            this.recognition.onerror = (event) => {
                console.error('Voice error:', event.error);
                this.isListening = false;
                this.showErrorResponse('Erreur: ' + event.error);
            };

            // Keyboard shortcut
            document.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.key === 'V') {
                    e.preventDefault();
                    this.toggleListening();
                }
            });
        },

        toggleListening() {
            if (!this.recognition) {
                this.showErrorResponse('La reconnaissance vocale n\'est pas supportée par votre navigateur.');
                return;
            }

            if (this.isListening) {
                this.recognition.stop();
                this.isListening = false;
            } else {
                // Reset state
                this.urgenceDeclared = false;
                this.smsSent = 0;
                this.emailsSent = 0;
                this.locationCaptured = false;
                
                this.recognition.start();
                this.isListening = true;
                this.speak('Je vous écoute...');
            }
        },

        async processCommand(text) {
            this.transcriptText = text;
            
            // Get user location for emergency
            let location = {};
            if (text.toLowerCase().includes('urgence') || text.toLowerCase().includes('urgent')) {
                try {
                    location = await this.getUserLocation();
                } catch (e) {
                    console.warn('Could not get location:', e);
                }
            }
            
            try {
                const response = await fetch('/voice/process', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        text: text,
                        latitude: location.latitude || null,
                        longitude: location.longitude || null
                    })
                });

                const data = await response.json();

                this.responseText = data.response;
                this.redirectUrl = data.redirect || '';
                this.showResponse = true;
                
                // Special handling for emergency
                if (data.urgence_declared) {
                    this.urgenceDeclared = true;
                    this.smsSent = data.sms_sent || 0;
                    this.emailsSent = data.emails_sent || 0;
                    this.locationCaptured = location.latitude !== undefined;
                    this.responseText = data.response;
                    this.speak('Urgence déclarée! Vos contacts ont été notifiés.');
                } else {
                    this.urgenceDeclared = false;
                    this.speak(data.response);
                }

                // Auto-redirect for emergency (faster)
                if (data.urgence_declared && data.redirect) {
                    setTimeout(() => {
                        window.location.href = data.redirect;
                    }, 2000);
                } else if (data.redirect) {
                    setTimeout(() => {
                        window.location.href = data.redirect;
                    }, 1500);
                }

            } catch (error) {
                console.error('Error:', error);
                this.showErrorResponse('Désolé, une erreur est survenue.');
            }
        },

        getUserLocation() {
            return new Promise((resolve, reject) => {
                if (!navigator.geolocation) {
                    reject(new Error('Geolocation not supported'));
                    return;
                }

                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        resolve({
                            latitude: position.coords.latitude,
                            longitude: position.coords.longitude
                        });
                    },
                    (error) => {
                        reject(error);
                    },
                    { 
                        enableHighAccuracy: true, 
                        timeout: 5000, 
                        maximumAge: 0 
                    }
                );
            });
        },

        speak(text) {
            if (this.synthesis) {
                this.synthesis.cancel();
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'fr-FR';
                utterance.rate = 0.9;
                utterance.pitch = 1;
                this.synthesis.speak(utterance);
            }
        },

        showErrorResponse(message) {
            this.responseText = message;
            this.showResponse = true;
            setTimeout(() => {
                this.showResponse = false;
            }, 3000);
        }
    };
}
</script>
