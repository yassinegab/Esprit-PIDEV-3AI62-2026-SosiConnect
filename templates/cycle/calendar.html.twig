{% extends 'base.html.twig' %}

{% block stylesheets %}
<style>
/* reuse existing styles for calendar and theme */
.fc {
  --fc-border-color: #fbcfe8;
  --fc-today-bg-color: #fce7f3;
  --fc-page-bg-color: #fff1f2;
  font-family: 'Inter', sans-serif;
}

.fc-toolbar-title { color: #be185d; font-weight: 600; }

.fc-button {
  background-color: #f9a8d4 !important;
  border: none !important;
  color: white !important;
}
.fc-button:hover { background-color: #f472b6 !important; }

.fc-daygrid-day-number { color: #9d174d; font-weight: 500; }
.fc-day-today { background-color: #fce7f3 !important; }

/* Custom Event Styles */
.menstruation-event { background-color: #ef4444 !important; border-color: #ef4444 !important; opacity: 0.8; }
.follicular-event { background-color: #3b82f6 !important; border-color: #3b82f6 !important; opacity: 0.4; }
.fertile-event { 
    background: linear-gradient(135deg, #10b981 0%, #34d399 100%) !important; 
    border-color: #10b981 !important; 
    opacity: 0.6; 
}
.ovulation-event { 
    background-color: #8b5cf6 !important; 
    border-color: #8b5cf6 !important; 
    border-radius: 50%;
    width: 20px;
    height: 20px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
}
.luteal-event { background-color: #eab308 !important; border-color: #eab308 !important; opacity: 0.4; }
.predicted-period { 
    background-color: #fca5a5 !important; 
    border: 2px dashed #ef4444 !important; 
    color: #ef4444 !important;
}

/* Tooltip */
.fc-event-tooltip {
    position: absolute;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 12px;
    pointer-events: none;
    transform: translate(-50%, -100%);
    margin-top: -10px;
}

/* Dashboard Summary Cards */
.summary-card {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border-left: 5px solid;
    transition: transform 0.2s;
}
.summary-card:hover { transform: translateY(-2px); }
</style>
{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-pink-50">
  <div class="flex flex-1 flex-col">
    {% include 'components/top-nav.html.twig' %}
    <main class="flex-1 overflow-auto">
      <div class="mx-auto max-w-7xl space-y-6 p-4 lg:p-6">
        
        <!-- Header & Actions -->
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between bg-white p-4 rounded-xl shadow-sm">
          <div>
            <h1 class="text-2xl font-bold text-pink-700">🌸 Mon Calendrier Menstruel</h1>
            <p class="text-sm text-gray-500">Suivez et prévoyez votre cycle avec précision</p>
          </div>
          <div class="flex gap-2">
            <a href="{{ path('cycle_new') }}" class="px-4 py-2 bg-pink-600 text-white rounded-lg hover:bg-pink-700 shadow transition flex items-center gap-2">
                <i class="fas fa-plus"></i> Ajouter règles
            </a>
            <a href="{{ path('cycle_analyse') }}" class="px-4 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 shadow transition flex items-center gap-2">
                <i class="fas fa-chart-line"></i> Analyser
            </a>
            <a href="{{ path('export_cycle_pdf') }}" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 shadow transition flex items-center gap-2">
                <i class="fas fa-file-pdf"></i> PDF
            </a>
          </div>
        </div>

        <!-- Notifications & Alerts -->
        {% if stats.notifications is defined and stats.notifications|length > 0 %}
        <div class="space-y-2">
            {% for notif in stats.notifications %}
            <div class="flex items-center gap-3 p-4 rounded-lg border-l-4 shadow-sm animate-pulse
                {% if notif.type == 'warning' %} bg-orange-50 border-orange-500 text-orange-700
                {% elseif notif.type == 'info' %} bg-blue-50 border-blue-500 text-blue-700
                {% elseif notif.type == 'danger' %} bg-red-50 border-red-500 text-red-700
                {% else %} bg-gray-50 border-gray-500 text-gray-700 {% endif %}">
                <i class="fas fa-bell"></i>
                <span class="font-medium">{{ notif.message }}</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        <!-- Summary Dashboard -->
        {% if stats %}
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="summary-card border-pink-500">
                <h3 class="text-gray-500 text-sm font-medium uppercase">Phase Actuelle</h3>
                <p class="text-2xl font-bold text-pink-600 mt-1">{{ stats.current_phase }}</p>
            </div>
            <div class="summary-card border-purple-500">
                <h3 class="text-gray-500 text-sm font-medium uppercase">Prochaines Règles</h3>
                <p class="text-xl font-bold text-purple-600 mt-1">{{ stats.next_period }}</p>
                <p class="text-xs text-gray-400">Estimé</p>
            </div>
            <div class="summary-card border-green-500">
                <h3 class="text-gray-500 text-sm font-medium uppercase">Ovulation</h3>
                <p class="text-xl font-bold text-green-600 mt-1">{{ stats.ovulation }}</p>
                <p class="text-xs text-gray-400">Fertilité max</p>
            </div>
            <div class="summary-card border-blue-500">
                <h3 class="text-gray-500 text-sm font-medium uppercase">Durée Moyenne</h3>
                <p class="text-2xl font-bold text-blue-600 mt-1">{{ stats.avg_length }} jours</p>
            </div>
        </div>
        {% endif %}

        <!-- Legend -->
        <div class="flex flex-wrap gap-4 text-sm bg-white p-3 rounded-lg shadow-sm justify-center">
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-red-500"></span> Règles</div>
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-blue-500 opacity-50"></span> Folliculaire</div>
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-green-500 opacity-60"></span> Fertile</div>
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-purple-500"></span> Ovulation</div>
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-yellow-500 opacity-50"></span> Lutéale</div>
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full border-2 border-dashed border-red-400"></span> Prévision</div>
        </div>

        <div id="calendar-wrapper" class="bg-white p-6 rounded-2xl shadow-lg">
            <div id="calendar"></div>
        </div>

        <!-- Hidden Action Buttons for JS -->
        <div class="hidden">
            <button id="btn-edit" disabled></button>
            <button id="btn-delete" disabled></button>
        </div>

      </div>
    </main>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const calendarEl = document.getElementById('calendar');
    const events = {{ calendarEvents|raw }};

    const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        locale: 'fr',
        headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,dayGridYear'
        },
        events: events,
        editable: false, // Set to true if you want drag & drop (requires backend update)
        selectable: true,
        eventClick: function(info) {
            // Only allow interaction with real menstruation events
            if (info.event.extendedProps.type === 'menstruation') {
                if (confirm('Voulez-vous modifier ce cycle ?')) {
                    window.location.href = `/cycle/${info.event.id}/edit`;
                }
            }
        },
        select: function(info) {
            if (confirm('Ajouter un nouveau cycle à cette date ?')) {
                // Redirect to new with start date pre-filled (requires updating controller to accept query param)
                window.location.href = `{{ path('cycle_new') }}?start=${info.startStr}`;
            }
        },
        eventDidMount: function(info) {
            // Tooltip logic
            let tooltip = document.createElement('div');
            tooltip.className = 'fc-event-tooltip';
            tooltip.innerHTML = info.event.title;
            
            info.el.addEventListener('mouseenter', () => {
                document.body.appendChild(tooltip);
                const rect = info.el.getBoundingClientRect();
                tooltip.style.left = rect.left + (rect.width / 2) + 'px';
                tooltip.style.top = rect.top + 'px';
            });
            
            info.el.addEventListener('mouseleave', () => {
                if (document.body.contains(tooltip)) {
                    document.body.removeChild(tooltip);
                }
            });
        }
    });

    calendar.render();
});
</script>
{% endblock %}
