{% extends 'emails/base.html.twig' %}

{% block title %}Mise à jour de votre don{% endblock %}

{% block content %}
<div style="text-align: center; padding: 20px 0;">
    <div style="font-size: 60px; margin-bottom: 20px;">
        {% if don.statut == 'VALIDÉ' %}✅{% elseif don.statut == 'REFUSÉ' %}❌{% else %}⏳{% endif %}
    </div>
    <h1 style="color: #1a1a2e; font-size: 28px; margin: 0 0 10px 0;">
        {% if don.statut == 'VALIDÉ' %}Votre don a été validé !{% elseif don.statut == 'REFUSÉ' %}Mise à jour de votre don{% else %}Mise à jour{% endif %}
    </h1>
    <p style="color: #666; font-size: 16px; margin: 0;">Bonjour {{ recipientName }},</p>
</div>

<div style="background: {% if don.statut == 'VALIDÉ' %}#dcfce7{% elseif don.statut == 'REFUSÉ' %}#fef2f2{% else %}#f8f9fa{% endif %}; border-radius: 12px; padding: 24px; margin: 20px 0;">
    <h2 style="color: #1a1a2e; font-size: 20px; margin: 0 0 16px 0;">Détails de votre don</h2>
    
    <table style="width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden;">
        <tr>
            <td style="padding: 14px 16px; border-bottom: 1px solid #eee; color: #666;">Type de don</td>
            <td style="padding: 14px 16px; border-bottom: 1px solid #eee; text-align: right; font-weight: 600; color: #1a1a2e;">
                {% if don.typeDon == 'sang' %}🩸 Don de Sang{% else %}🫀 Don d'Organe{% endif %}
            </td>
        </tr>
        <tr>
            <td style="padding: 14px 16px; border-bottom: 1px solid #eee; color: #666;">Région</td>
            <td style="padding: 14px 16px; border-bottom: 1px solid #eee; text-align: right; font-weight: 600; color: #1a1a2e;">{{ don.region }}</td>
        </tr>
        <tr>
            <td style="padding: 14px 16px; border-bottom: 1px solid #eee; color: #666;">Date</td>
            <td style="padding: 14px 16px; border-bottom: 1px solid #eee; text-align: right; font-weight: 600; color: #1a1a2e;">{{ don.dateDon|date('d/m/Y') }}</td>
        </tr>
        <tr>
            <td style="padding: 14px 16px; color: #666;">Statut</td>
            <td style="padding: 14px 16px; text-align: right; font-weight: 700; color: {% if don.statut == 'VALIDÉ' %}#16a34a{% elseif don.statut == 'REFUSÉ' %}#dc2626{% else %}#666{% endif %};">
                {{ don.statut }}
            </td>
        </tr>
    </table>
</div>

{% if don.statut == 'VALIDÉ' %}
<div style="text-align: center; margin: 30px 0;">
    <a href="{{ url('don_history') }}" 
       style="display: inline-block; background: linear-gradient(135deg, #7c3aed, #6d28d9); color: white; padding: 16px 40px; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
        📜 Télécharger mon certificat
    </a>
</div>

<div style="background: #dcfce7; border-left: 4px solid #16a34a; padding: 16px; border-radius: 8px; margin: 20px 0;">
    <p style="margin: 0; color: #166534; font-size: 14px;">
        <strong>🎉 Merci !</strong> Votre don a été validé. Vous pouvez désormais télécharger votre certificat de don.
    </p>
</div>
{% endif %}
{% endblock %}
