{% extends 'layout/front-layout.html.twig' %}

{% block title %}FAQ - Centre d'Aide{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="/css/modern-styles.css">
{% endblock %}

{% block content %}
<div class="space-y-6 animate-fadeIn">
    <div class="flex items-center gap-4">
        <a href="{{ path('aide') }}" class="text-gray-500 hover:text-gray-700 transition">
            ← Retour
        </a>
        <h1 class="text-2xl font-bold text-gray-800">❓ Foire Aux Questions</h1>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
        <form method="get" class="flex gap-4">
            <div class="flex-1 relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">🔍</span>
                <input type="text" name="search" value="{{ search }}"
                       placeholder="Rechercher dans la FAQ..."
                       class="w-full pl-12 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition">
            </div>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition">
                Rechercher
            </button>
            {% if search %}
            <a href="{{ path('aide_faq') }}" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-3 rounded-xl transition">
                ✕
            </a>
            {% endif %}
        </form>
    </div>

    <div class="flex gap-4 flex-wrap">
        <a href="{{ path('aide_faq') }}" class="px-4 py-2 rounded-full text-sm font-medium transition {{ not currentCategory ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' }}">
            Toutes
        </a>
        {% for category in categories %}
        <a href="{{ path('aide_faq', {category: category}) }}" class="px-4 py-2 rounded-full text-sm font-medium transition {{ currentCategory == category ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' }}">
            {{ category|title }}
        </a>
        {% endfor %}
    </div>

    <div class="space-y-4">
        {% for faq in faqs %}
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden" x-data="{ open: false }">
            <button @click="open = !open; if(!open) fetch('{{ path('aide_faq_view', {id: faq.id}) }}')"
                    class="w-full p-6 text-left flex justify-between items-center hover:bg-gray-50 transition">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-xl flex-shrink-0">
                        ❓
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-800 text-lg">{{ faq.question }}</h3>
                        <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                            <span>📁 {{ faq.category }}</span>
                            <span>👁 {{ faq.viewCount }} vues</span>
                            <span>👍 {{ faq.helpfulCount }} utiles</span>
                        </div>
                    </div>
                </div>
                <span class="text-gray-400 text-2xl transition-transform" :class="open ? 'rotate-180' : ''">
                    ▼
                </span>
            </button>
            
            <div x-show="open" x-collapse class="border-t border-gray-100">
                <div class="p-6 bg-gray-50">
                    <p class="text-gray-700 leading-relaxed">{{ faq.answer|nl2br }}</p>
                    
                    <div class="mt-6 pt-4 border-t border-gray-200 flex items-center justify-between">
                        <span class="text-sm text-gray-500">Cette réponse vous a-t-elle aidé ?</span>
                        <div class="flex gap-2">
                            <button @click="$fetch('{{ path('aide_faq_helpful', {id: faq.id}) }}', {method: 'POST'})"
                                    class="px-4 py-2 bg-green-100 text-green-700 rounded-lg hover:bg-green-200 transition text-sm font-medium flex items-center gap-2">
                                👍 Oui
                            </button>
                            <button class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition text-sm font-medium flex items-center gap-2">
                                👎 Non
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="bg-white rounded-2xl p-12 shadow-lg border border-gray-100 text-center">
            <div class="text-6xl mb-4">🔍</div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Aucune question trouvée</h3>
            <p class="text-gray-500 mb-6">
                {% if search %}
                    Aucun résultat pour "{{ search }}"
                {% else %}
                    Aucune question disponible dans cette catégorie
                {% endif %}
            </p>
            <a href="{{ path('aide_support_new') }}" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition">
                🎫 Créer un ticket de support
            </a>
        </div>
        {% endfor %}
    </div>

    {% if faqs|length > 0 %}
    <div class="bg-gradient-to-r from-purple-50 to-indigo-50 rounded-2xl p-6 border border-purple-100">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <h3 class="font-bold text-gray-800">Vous n'avez pas trouvé votre réponse ?</h3>
                <p class="text-gray-600 text-sm">Notre équipe de support est là pour vous aider.</p>
            </div>
            <a href="{{ path('aide_support_new') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-xl font-semibold transition shadow-lg">
                🎫 Contacter le support
            </a>
        </div>
    </div>
    {% endif %}
</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.directive('collapse', (el, { expression }, { effect, evaluateLater }) => {
        let open = evaluateLater(expression);
        
        effect(() => {
            open(value => {
                if (value) {
                    el.style.height = 'auto';
                    el.style.overflow = 'visible';
                } else {
                    el.style.height = '0';
                    el.style.overflow = 'hidden';
                }
            });
        });
    });
});
</script>
{% endblock %}
