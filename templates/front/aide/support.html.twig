{% extends 'layout/front-layout.html.twig' %}

{% block title %}Mes Tickets - Support{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="/css/modern-styles.css">
{% endblock %}

{% block content %}
<div class="space-y-6 animate-fadeIn">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">🎫 Mes Tickets</h1>
            <p class="text-gray-500">Suivez l'état de vos demandes de support</p>
        </div>
        <a href="{{ path('aide_support_new') }}" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition shadow-lg flex items-center gap-2">
            <span>➕</span> Nouveau ticket
        </a>
    </div>

    {% for message in app.flashes('success') %}
    <div class="bg-green-100 border-l-4 border-green-500 text-green-700 px-4 py-3 rounded-lg">
        ✅ {{ message }}
    </div>
    {% endfor %}

    {% if tickets|length > 0 %}
    <div class="space-y-4">
        {% for ticket in tickets %}
        <a href="{{ path('aide_support_view', {id: ticket.id}) }}" 
           class="block bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition group">
            <div class="flex justify-between items-start">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 {{ ticket.status == 'open' ? 'bg-blue-100' : ticket.status == 'resolved' ? 'bg-green-100' : 'bg-gray-100' }} rounded-xl flex items-center justify-center text-2xl">
                        {% if ticket.status == 'open' %}
                            🎫
                        {% elseif ticket.status == 'in_progress' %}
                            💬
                        {% elseif ticket.status == 'resolved' %}
                            ✅
                        {% else %}
                            📁
                        {% endif %}
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-800 group-hover:text-blue-600 transition">
                            {{ ticket.subject }}
                        </h3>
                        <p class="text-sm text-gray-500 mt-1 line-clamp-1">{{ ticket.description|slice(0, 100) }}...</p>
                        <div class="flex items-center gap-4 mt-2 text-xs text-gray-400">
                            <span>#{{ ticket.id }}</span>
                            <span>📅 {{ ticket.createdAt|date('d/m/Y H:i') }}</span>
                            <span>📁 {{ ticket.category }}</span>
                            {% if ticket.messages|length > 0 %}
                            <span>💬 {{ ticket.messages|length }} message(s)</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <span class="px-3 py-1 {{ ticket.statusBadgeClass }} rounded-full text-xs font-semibold">
                        {{ ticket.status|replace({'_': ' '})|title }}
                    </span>
                    <span class="px-3 py-1 {{ ticket.priorityBadgeClass }} rounded-full text-xs font-semibold">
                        {{ ticket.priority|upper }}
                    </span>
                </div>
            </div>
        </a>
        {% endfor %}
    </div>
    {% else %}
    <div class="bg-white rounded-2xl p-12 shadow-lg border border-gray-100 text-center">
        <div class="text-6xl mb-4">🎫</div>
        <h3 class="text-xl font-bold text-gray-800 mb-2">Aucun ticket</h3>
        <p class="text-gray-500 mb-6">Vous n'avez pas encore créé de ticket de support.</p>
        <a href="{{ path('aide_support_new') }}" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition">
            🎫 Créer mon premier ticket
        </a>
    </div>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
            <h3 class="font-semibold text-gray-800 mb-4">📊 Statut des tickets</h3>
            <div class="space-y-3">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-600">Ouverts</span>
                    </div>
                    <span class="font-semibold">{{ tickets|filter(t => t.status == 'open')|length }}</span>
                </div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                        <span class="text-gray-600">En cours</span>
                    </div>
                    <span class="font-semibold">{{ tickets|filter(t => t.status == 'in_progress')|length }}</span>
                </div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                        <span class="text-gray-600">Résolus</span>
                    </div>
                    <span class="font-semibold">{{ tickets|filter(t => t.status == 'resolved')|length }}</span>
                </div>
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 bg-gray-500 rounded-full"></div>
                        <span class="text-gray-600">Fermés</span>
                    </div>
                    <span class="font-semibold">{{ tickets|filter(t => t.status == 'closed')|length }}</span>
                </div>
            </div>
        </div>

        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 border border-blue-100">
            <h3 class="font-semibold text-blue-800 mb-4">💡 Besoin d'aide rapide ?</h3>
            <p class="text-sm text-blue-700 mb-4">
                Avant de créer un ticket, consultez notre FAQ. Vous y trouverez peut-être la réponse à votre question !
            </p>
            <a href="{{ path('aide_faq') }}" class="block w-full bg-white hover:bg-blue-50 text-blue-600 text-center py-3 rounded-xl font-medium transition border border-blue-200">
                ❓ Consulter la FAQ
            </a>
        </div>
    </div>
</div>
{% endblock %}
