{% extends 'layout/front-layout.html.twig' %}

{% block title %}{{ tutorial.title }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="/css/modern-styles.css">
<style>
.video-container {
    position: relative;
    padding-top: 56.25%;
    background: #000;
    border-radius: 1rem;
    overflow: hidden;
}
.video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}
</style>
{% endblock %}

{% block content %}
<div class="space-y-6 animate-fadeIn">
    <div class="flex items-center gap-4">
        <a href="{{ path('aide_tutorials') }}" class="text-gray-500 hover:text-gray-700 transition">
            ← Retour aux tutoriels
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100">
                <div class="video-container">
                    <iframe src="{{ tutorial.embedUrl }}" 
                            frameborder="0" 
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                            allowfullscreen></iframe>
                </div>
                
                <div class="p-6">
                    <div class="flex items-start justify-between">
                        <div>
                            <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">
                                {{ tutorial.category }}
                            </span>
                            <h1 class="text-2xl font-bold text-gray-800 mt-3">{{ tutorial.title }}</h1>
                        </div>
                        <span class="text-sm text-gray-500 bg-gray-100 px-3 py-1 rounded-lg">
                            {{ tutorial.durationFormatted }}
                        </span>
                    </div>
                    
                    <p class="text-gray-600 mt-4 leading-relaxed">{{ tutorial.description }}</p>
                    
                    <div class="flex items-center gap-6 mt-6 pt-4 border-t border-gray-100">
                        <span class="text-sm text-gray-500">
                            👁 {{ tutorial.viewCount }} vues
                        </span>
                        <span class="text-sm text-gray-500">
                            📅 {{ tutorial.createdAt|date('d/m/Y') }}
                        </span>
                        <form method="post" action="{{ path('aide_tutorial_like', {id: tutorial.id}) }}" class="ml-auto">
                            <button type="submit" class="flex items-center gap-2 text-gray-600 hover:text-red-600 transition">
                                👍 <span>{{ tutorial.likeCount }}</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="space-y-4">
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100">
                <h3 class="font-bold text-gray-800 mb-4">📁 Catégorie</h3>
                <a href="{{ path('aide_tutorials', {category: tutorial.category}) }}" 
                   class="inline-block px-4 py-2 bg-blue-100 text-blue-700 rounded-xl font-medium hover:bg-blue-200 transition">
                    {{ tutorial.category }}
                </a>
            </div>

            <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-6 border border-blue-100">
                <h3 class="font-bold text-blue-800 mb-3">💡 Astuce</h3>
                <p class="text-sm text-blue-700">
                    Partagez ce tutoriel avec vos amis pour les aider à utiliser nos services !
                </p>
                <div class="flex gap-2 mt-4">
                    <a href="https://www.facebook.com/sharer/sharer.php?u={{ app.request.uri }}" target="_blank"
                       class="w-10 h-10 bg-blue-600 text-white rounded-lg flex items-center justify-center hover:bg-blue-700 transition">
                        f
                    </a>
                    <a href="https://twitter.com/intent/tweet?text={{ tutorial.title }}&url={{ app.request.uri }}" target="_blank"
                       class="w-10 h-10 bg-sky-500 text-white rounded-lg flex items-center justify-center hover:bg-sky-600 transition">
                        𝕏
                    </a>
                    <a href="https://wa.me/?text={{ tutorial.title }} {{ app.request.uri }}" target="_blank"
                       class="w-10 h-10 bg-green-500 text-white rounded-lg flex items-center justify-center hover:bg-green-600 transition">
                        💬
                    </a>
                </div>
            </div>

            <a href="{{ path('aide_support_new') }}" 
               class="block bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition">
                <div class="flex items-center gap-3">
                    <span class="text-2xl">❓</span>
                    <div>
                        <p class="font-medium text-gray-800">Besoin d'aide ?</p>
                        <p class="text-sm text-gray-500">Contacter le support</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
{% endblock %}
