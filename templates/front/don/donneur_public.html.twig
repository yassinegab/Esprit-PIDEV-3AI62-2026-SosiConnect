{% extends 'base.html.twig' %}

{% block title %}Carte de Donneur - {{ donneur.prenom }} {{ donneur.nom }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.donor-card-container {
    max-width: 500px;
    margin: 60px auto;
    padding: 20px;
}
.donor-card {
    background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
    border-radius: 24px;
    padding: 40px;
    color: white;
    position: relative;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(220, 38, 38, 0.3);
}
.donor-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
}
.card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 30px;
    position: relative;
    z-index: 1;
}
.card-logo {
    font-size: 32px;
}
.card-title {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.8;
}
.blood-type-badge {
    background: rgba(255,255,255,0.2);
    padding: 15px 25px;
    border-radius: 16px;
    text-align: center;
}
.blood-type-label {
    font-size: 10px;
    text-transform: uppercase;
    opacity: 0.8;
    margin-bottom: 5px;
}
.blood-type-value {
    font-size: 28px;
    font-weight: bold;
}
.donor-info {
    position: relative;
    z-index: 1;
    margin-bottom: 30px;
}
.donor-name {
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 5px;
}
.donor-id {
    font-size: 12px;
    opacity: 0.7;
}
.card-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin-bottom: 30px;
    position: relative;
    z-index: 1;
}
.detail-item {
    background: rgba(255,255,255,0.1);
    padding: 15px;
    border-radius: 12px;
}
.detail-label {
    font-size: 10px;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 5px;
}
.detail-value {
    font-size: 14px;
    font-weight: 600;
}
.card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.2);
    position: relative;
    z-index: 1;
}
.qr-section {
    text-align: center;
}
.qr-code-img {
    width: 100px;
    height: 100px;
    background: white;
    padding: 10px;
    border-radius: 12px;
}
.qr-label {
    font-size: 10px;
    margin-top: 10px;
    opacity: 0.8;
}
.status-section {
    text-align: right;
}
.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.2);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}
.status-active {
    background: #22c55e;
}
.emergency-notice {
    margin-top: 30px;
    background: white;
    border-radius: 16px;
    padding: 20px;
    text-align: center;
}
.emergency-title {
    color: #dc2626;
    font-weight: bold;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}
.emergency-text {
    color: #6b7280;
    font-size: 14px;
    line-height: 1.6;
}
</style>
{% endblock %}

{% block body %}
<div class="donor-card-container">
    <div class="donor-card">
        <div class="card-header">
            <div>
                <div class="card-logo">🩸</div>
                <div class="card-title">Carte de Donneur</div>
            </div>
            <div class="blood-type-badge">
                <div class="blood-type-label">Groupe Sanguin</div>
                <div class="blood-type-value">{{ donneur.groupeSanguin }}</div>
            </div>
        </div>
        
        <div class="donor-info">
            <div class="donor-name">{{ donneur.prenom }} {{ donneur.nom }}</div>
            <div class="donor-id">ID: DON-{{ "%06d"|format(donneur.id) }}</div>
        </div>
        
        <div class="card-details">
            <div class="detail-item">
                <div class="detail-label">Âge</div>
                <div class="detail-value">{{ donneur.age }} ans</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Téléphone</div>
                <div class="detail-value">{{ donneur.telephone }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Date d'inscription</div>
                <div class="detail-value">{{ donneur.dateInscription|date('d/m/Y') ?? 'N/A' }}</div>
            </div>
            <div class="detail-item">
                <div class="detail-label">Dernier don</div>
                <div class="detail-value">{{ donneur.dernierDon|date('d/m/Y') ?? 'Aucun' }}</div>
            </div>
        </div>
        
        <div class="card-footer">
            <div class="qr-section">
                <img src="{{ qr_code }}" alt="QR Code" class="qr-code-img">
                <div class="qr-label">Scannez pour accéder</div>
            </div>
            <div class="status-section">
                <div class="status-badge {% if donneur.disponible %}status-active{% endif %}">
                    {% if donneur.disponible %}
                        <span>✓</span> Disponible
                    {% else %}
                        <span>○</span> Indisponible
                    {% endif %}
                </div>
                <div style="margin-top: 10px; font-size: 10px; opacity: 0.7;">
                    Wellness Connect
                </div>
            </div>
        </div>
    </div>
    
    <div class="emergency-notice">
        <div class="emergency-title">
            <span>🚨</span> En cas d'urgence
        </div>
        <p class="emergency-text">
            Cette carte peut être présentée aux services médicaux en cas d'urgence.<br>
            Le groupe sanguin du donneur est immédiatement visible pour faciliter les soins.
        </p>
    </div>
    
    <div style="text-align: center; margin-top: 20px;">
        <a href="{{ path('don') }}" style="color: #6b7280; text-decoration: none; font-size: 14px;">
            ← Retour au module Don
        </a>
    </div>
</div>
{% endblock %}
