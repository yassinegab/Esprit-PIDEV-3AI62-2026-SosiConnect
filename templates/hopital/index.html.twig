{% extends 'base.html.twig' %}

{% block title %}Hôpitaux & Cliniques — SmartHealth AI{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-gray-50">
    {% include 'components/sidebar.html.twig' %}

    <div class="flex flex-1 flex-col lg:ml-72">
        {% include 'components/top-nav.html.twig' %}

        <main class="flex-1 overflow-auto pb-12">
            <div class="mx-auto max-w-7xl space-y-6 p-4 lg:p-8">

                {# ── Header ── #}
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
                            <i class="fas fa-hospital text-purple-600"></i>
                            Hôpitaux & Cliniques
                        </h1>
                        <p class="text-gray-500 mt-1 text-sm">
                            {{ hopitaux|length }} établissement(s) —
                            <span class="text-green-600 font-medium">{{ geo_count }} localisé(s) sur la carte</span>
                        </p>
                    </div>
                    <a href="{{ path('app_service_home') }}"
                       class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-semibold rounded-lg hover:bg-gray-200 transition text-sm">
                        <i class="fas fa-arrow-left"></i> Retour
                    </a>
                </div>

                {# ── Onglets Vue ── #}
                <div class="flex gap-2 border-b border-gray-200">
                    <button id="tab-map"
                            onclick="showTab('map')"
                            class="tab-btn px-5 py-2.5 text-sm font-semibold border-b-2 border-blue-600 text-blue-600 transition">
                        <i class="fas fa-map-marked-alt mr-2"></i>Carte
                    </button>
                    <button id="tab-list"
                            onclick="showTab('list')"
                            class="tab-btn px-5 py-2.5 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition">
                        <i class="fas fa-list mr-2"></i>Liste
                    </button>
                </div>

                {# ════════════════════════════════════════════
                   VUE CARTE — Google Maps API (API externe #2)
                   ════════════════════════════════════════════ #}
                <div id="view-map">

                    {# Légende #}
                    <div class="flex flex-wrap items-center gap-4 mb-3 text-sm text-gray-600">
                        <span class="flex items-center gap-2">
                            <span class="w-4 h-4 rounded-full bg-red-500 inline-block shadow"></span>
                            Urgences disponibles
                        </span>
                        <span class="flex items-center gap-2">
                            <span class="w-4 h-4 rounded-full bg-blue-500 inline-block shadow"></span>
                            Sans urgences
                        </span>
                        <span class="ml-auto flex items-center gap-1 px-3 py-1 bg-blue-50 text-blue-700 rounded-full font-semibold text-xs border border-blue-200">
                            <i class="fab fa-google"></i> Google Maps API
                        </span>
                    </div>

                    {# La carte #}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-md overflow-hidden">
                        <div id="map" style="height: 500px; width: 100%;"></div>

                        {# Barre infos hôpital sélectionné #}
                        <div id="map-info-bar"
                             class="hidden border-t border-gray-100 p-4 bg-gradient-to-r from-blue-50 to-purple-50">
                            <div class="flex items-center justify-between flex-wrap gap-3">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-hospital text-white text-lg"></i>
                                    </div>
                                    <div>
                                        <p id="info-nom" class="font-bold text-gray-900 text-base"></p>
                                        <p id="info-adresse" class="text-gray-500 text-sm"></p>
                                        <div class="flex gap-2 mt-1">
                                            <span id="info-urgences-yes"
                                                  class="hidden px-2 py-0.5 bg-green-100 text-green-800 text-xs font-semibold rounded-full">
                                                <i class="fas fa-ambulance mr-1"></i>Urgences 24/7
                                            </span>
                                            <span id="info-urgences-no"
                                                  class="hidden px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-full">
                                                Sans urgences
                                            </span>
                                            <span id="info-capacite"
                                                  class="px-2 py-0.5 bg-blue-100 text-blue-800 text-xs rounded-full">
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    <a id="info-tel-link" href="#"
                                       class="inline-flex items-center gap-1 px-4 py-2 bg-green-600 text-white text-sm font-semibold rounded-lg hover:bg-green-700 transition">
                                        <i class="fas fa-phone"></i>
                                        <span id="info-tel"></span>
                                    </a>
                                    <a id="info-rdv-link" href="{{ path('app_rendez_vous_new') }}"
                                       class="inline-flex items-center gap-1 px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition">
                                        <i class="fas fa-calendar-plus"></i> Réserver
                                    </a>
                                    <a id="info-detail-link" href="#"
                                       class="inline-flex items-center gap-1 px-4 py-2 bg-purple-600 text-white text-sm font-semibold rounded-lg hover:bg-purple-700 transition">
                                        <i class="fas fa-info-circle"></i> Détails
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Mini-cards sous la carte — navigation rapide #}
                    {% if geo_count > 0 %}
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-4">
                        {% for hopital in hopitaux %}
                            {% if hopital.latitude and hopital.longitude %}
                            <button onclick="focusHopital({{ hopital.id }})"
                                    class="text-left bg-white border border-gray-200 rounded-xl p-3 hover:border-purple-400 hover:shadow-md transition group">
                                <div class="flex items-center gap-2 mb-1">
                                    <div class="w-7 h-7 {% if hopital.serviceUrgenceDispo %}bg-red-500{% else %}bg-blue-500{% endif %} rounded-full flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-map-pin text-white text-xs"></i>
                                    </div>
                                    <p class="font-semibold text-gray-800 text-xs leading-tight group-hover:text-purple-700 transition truncate">
                                        {{ hopital.nom }}
                                    </p>
                                </div>
                                <p class="text-xs text-gray-400 truncate pl-9">{{ hopital.adresse }}</p>
                            </button>
                            {% endif %}
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>

                {# ════════════════════════
                   VUE LISTE — Cards
                   ════════════════════════ #}
                <div id="view-list" class="hidden">
                    {% if hopitaux is empty %}
                        <div class="bg-white rounded-xl border border-gray-200 p-16 text-center">
                            <i class="fas fa-hospital text-gray-300 text-6xl mb-4 block"></i>
                            <p class="text-gray-500 text-lg">Aucun hôpital référencé</p>
                        </div>
                    {% else %}
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                            {% for hopital in hopitaux %}
                            <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all overflow-hidden flex flex-col">
                                <div class="h-1.5 {% if hopital.serviceUrgenceDispo %}bg-gradient-to-r from-green-400 to-emerald-500{% else %}bg-gray-200{% endif %}"></div>

                                <div class="p-5 flex-1 flex flex-col">
                                    <div class="flex items-start gap-3 mb-4">
                                        <div class="w-11 h-11 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
                                            <i class="fas fa-hospital text-purple-600 text-lg"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h3 class="font-bold text-gray-900 text-sm leading-tight">{{ hopital.nom }}</h3>
                                            {% if hopital.serviceUrgenceDispo %}
                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-green-100 text-green-800 text-xs font-semibold rounded-full mt-1">
                                                    <i class="fas fa-ambulance text-xs"></i> Urgences 24/7
                                                </span>
                                            {% else %}
                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-gray-100 text-gray-500 text-xs rounded-full mt-1">
                                                    Sans urgences
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="space-y-2 mb-4 flex-1 text-sm">
                                        <div class="flex items-start gap-2 text-gray-600">
                                            <i class="fas fa-map-marker-alt text-red-400 mt-0.5 flex-shrink-0"></i>
                                            <span class="text-xs leading-relaxed">{{ hopital.adresse }}</span>
                                        </div>
                                        <div class="flex items-center gap-2 text-gray-600">
                                            <i class="fas fa-phone text-green-400 flex-shrink-0"></i>
                                            <a href="tel:{{ hopital.tel }}" class="text-xs hover:text-green-600 transition">{{ hopital.tel }}</a>
                                        </div>
                                        {% if hopital.capacite %}
                                        <div class="flex items-center gap-2 text-gray-600">
                                            <i class="fas fa-bed text-blue-400 flex-shrink-0"></i>
                                            <span class="text-xs">{{ hopital.capacite }} lits</span>
                                        </div>
                                        {% endif %}
                                        {% if hopital.specialites %}
                                        <div class="flex flex-wrap gap-1 pt-1">
                                            {% for spec in hopital.getSpecialitesArray() %}
                                                <span class="px-2 py-0.5 bg-purple-50 text-purple-700 text-xs rounded-full">{{ spec }}</span>
                                            {% endfor %}
                                        </div>
                                        {% endif %}
                                    </div>

                                    <div class="flex gap-2">
                                        <a href="{{ path('app_rendez_vous_new') }}"
                                           class="flex-1 px-3 py-2 bg-blue-600 text-white text-center text-xs font-semibold rounded-lg hover:bg-blue-700 transition">
                                            <i class="fas fa-calendar-plus mr-1"></i> Réserver
                                        </a>
                                        <a href="{{ path('app_hopital_show', {'id': hopital.id}) }}"
                                           class="px-3 py-2 bg-purple-100 text-purple-700 text-xs font-semibold rounded-lg hover:bg-purple-200 transition"
                                           title="Voir sur la carte">
                                            <i class="fas fa-map-marker-alt"></i>
                                        </a>
                                        {% if hopital.latitude and hopital.longitude %}
                                        <button onclick="showTab('map'); focusHopital({{ hopital.id }})"
                                                class="px-3 py-2 bg-gray-100 text-gray-600 text-xs font-semibold rounded-lg hover:bg-gray-200 transition"
                                                title="Centrer sur la carte">
                                            <i class="fas fa-crosshairs"></i>
                                        </button>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

            </div>
        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ══════════════════════════════════════════════════════════
// DONNÉES DES HÔPITAUX — injectées depuis Symfony (Twig)
// ══════════════════════════════════════════════════════════
const HOPITAUX_DATA = {{ hopitaux_geo|json_encode|raw }};

// ══════════════════════════════════════════════════════════
// GESTION DES ONGLETS (Carte / Liste)
// ══════════════════════════════════════════════════════════
function showTab(tab) {
    document.getElementById('view-map').classList.toggle('hidden', tab !== 'map');
    document.getElementById('view-list').classList.toggle('hidden', tab !== 'list');
    document.getElementById('tab-map').className =
        tab === 'map'
        ? 'tab-btn px-5 py-2.5 text-sm font-semibold border-b-2 border-blue-600 text-blue-600 transition'
        : 'tab-btn px-5 py-2.5 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition';
    document.getElementById('tab-list').className =
        tab === 'list'
        ? 'tab-btn px-5 py-2.5 text-sm font-semibold border-b-2 border-blue-600 text-blue-600 transition'
        : 'tab-btn px-5 py-2.5 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition';
}

// ══════════════════════════════════════════════════════════
// GOOGLE MAPS — initialisation
// ══════════════════════════════════════════════════════════
let map, markers = {}, infoWindow, activeMarker = null;

function initMap() {
    // Centre par défaut : Tunis
    const defaultCenter = HOPITAUX_DATA.length > 0
        ? { lat: HOPITAUX_DATA[0].lat, lng: HOPITAUX_DATA[0].lng }
        : { lat: 36.8189, lng: 10.1657 };

    map = new google.maps.Map(document.getElementById('map'), {
        zoom: 12,
        center: defaultCenter,
        mapTypeControl: false,
        streetViewControl: false,
        fullscreenControl: true,
        zoomControl: true,
        styles: [
            { elementType: 'geometry', stylers: [{ color: '#f5f5f5' }] },
            { elementType: 'labels.icon', stylers: [{ visibility: 'off' }] },
            { elementType: 'labels.text.fill', stylers: [{ color: '#616161' }] },
            { elementType: 'labels.text.stroke', stylers: [{ color: '#f5f5f5' }] },
            { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#ffffff' }] },
            { featureType: 'road.arterial', elementType: 'labels.text.fill', stylers: [{ color: '#757575' }] },
            { featureType: 'road.highway', elementType: 'geometry', stylers: [{ color: '#dadada' }] },
            { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#c9d8e8' }] },
            { featureType: 'poi.park', elementType: 'geometry', stylers: [{ color: '#e5f0e5' }] },
        ]
    });

    infoWindow = new google.maps.InfoWindow();

    // Créer les marqueurs
    HOPITAUX_DATA.forEach(h => {
        const icon = {
            path: google.maps.SymbolPath.CIRCLE,
            fillColor: h.urgences ? '#ef4444' : '#3b82f6',
            fillOpacity: 1,
            strokeColor: '#ffffff',
            strokeWeight: 3,
            scale: 12,
        };

        const marker = new google.maps.Marker({
            position: { lat: h.lat, lng: h.lng },
            map: map,
            title: h.nom,
            icon: icon,
            animation: google.maps.Animation.DROP,
        });

        marker.addListener('click', () => selectHopital(h, marker));
        markers[h.id] = marker;
    });

    // Ajuster la vue pour inclure tous les marqueurs
    if (HOPITAUX_DATA.length > 1) {
        const bounds = new google.maps.LatLngBounds();
        HOPITAUX_DATA.forEach(h => bounds.extend({ lat: h.lat, lng: h.lng }));
        map.fitBounds(bounds);
    }
}

// Sélectionner un hôpital sur la carte
function selectHopital(h, marker) {
    // Reset marqueur précédent
    if (activeMarker) {
        const prev = HOPITAUX_DATA.find(x => x.id === activeMarker);
        if (prev) {
            markers[prev.id].setIcon({
                path: google.maps.SymbolPath.CIRCLE,
                fillColor: prev.urgences ? '#ef4444' : '#3b82f6',
                fillOpacity: 1,
                strokeColor: '#ffffff',
                strokeWeight: 3,
                scale: 12,
            });
        }
    }

    // Marqueur actif — plus grand + jaune
    marker.setIcon({
        path: google.maps.SymbolPath.CIRCLE,
        fillColor: '#f59e0b',
        fillOpacity: 1,
        strokeColor: '#ffffff',
        strokeWeight: 3,
        scale: 16,
    });
    marker.setAnimation(google.maps.Animation.BOUNCE);
    setTimeout(() => marker.setAnimation(null), 1400);
    activeMarker = h.id;

    // Centrer la carte
    map.panTo({ lat: h.lat, lng: h.lng });

    // Remplir la barre d'info
    document.getElementById('map-info-bar').classList.remove('hidden');
    document.getElementById('info-nom').textContent = h.nom;
    document.getElementById('info-adresse').textContent = h.adresse;
    document.getElementById('info-tel').textContent = h.tel;
    document.getElementById('info-tel-link').href = 'tel:' + h.tel;
    document.getElementById('info-detail-link').href = h.url;
    document.getElementById('info-capacite').textContent = h.capacite ? h.capacite + ' lits' : '';
    document.getElementById('info-urgences-yes').classList.toggle('hidden', !h.urgences);
    document.getElementById('info-urgences-no').classList.toggle('hidden', h.urgences);
}

// Focuser sur un hôpital depuis la mini-card ou la liste
function focusHopital(id) {
    const h = HOPITAUX_DATA.find(x => x.id === id);
    if (!h) return;
    if (!markers[id]) return;
    showTab('map');
    map.setZoom(15);
    map.panTo({ lat: h.lat, lng: h.lng });
    selectHopital(h, markers[id]);
}

// Gestion erreur clé API
window.gm_authFailure = function () {
    document.getElementById('map').innerHTML = `
        <div style="height:500px;display:flex;align-items:center;justify-content:center;
                    background:#f9fafb;flex-direction:column;gap:16px;">
            <div style="width:64px;height:64px;background:#fee2e2;border-radius:50%;
                        display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-exclamation-triangle" style="color:#dc2626;font-size:24px;"></i>
            </div>
            <div style="text-align:center;">
                <p style="font-weight:bold;color:#1f2937;margin:0 0 6px;">Clé Google Maps API invalide</p>
                <p style="color:#6b7280;font-size:13px;margin:0;">
                    Remplacez <strong>VOTRE_CLE_API</strong> dans le script src ci-dessous.
                </p>
                <p style="color:#9ca3af;font-size:12px;margin-top:6px;">
                    Obtenez une clé gratuite sur : console.cloud.google.com
                </p>
            </div>
        </div>`;
};
</script>

{# ✅ Google Maps JavaScript API — Remplacez VOTRE_CLE_API #}
{# Obtenir une clé : https://console.cloud.google.com/apis/credentials #}
{# Activer : Maps JavaScript API dans la bibliothèque #}
<script
    src="https://maps.googleapis.com/maps/api/js?key=VOTRE_CLE_API&callback=initMap&loading=async"
    async defer>
</script>
{% endblock %}
