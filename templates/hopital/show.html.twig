{% extends 'base.html.twig' %}

{% block title %}{{ hopital.nom }} — SmartHealth AI{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-gray-50">
    {% include 'components/sidebar.html.twig' %}

    <div class="flex flex-1 flex-col lg:ml-72">
        {% include 'components/top-nav.html.twig' %}

        <main class="flex-1 overflow-auto pb-12">
            <div class="mx-auto max-w-6xl space-y-6 p-4 lg:p-8">

                {# ── Header ── #}
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                        <div class="flex items-center gap-3 flex-wrap">
                            <h1 class="text-3xl font-bold text-gray-900">{{ hopital.nom }}</h1>
                            {% if hopital.serviceUrgenceDispo %}
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-100 text-green-800 text-sm font-bold rounded-full">
                                    <i class="fas fa-ambulance"></i> Urgences 24h/24
                                </span>
                            {% else %}
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 text-sm rounded-full">
                                    Sans urgences
                                </span>
                            {% endif %}
                        </div>
                        <p class="text-gray-500 mt-1 flex items-center gap-2 text-sm">
                            <i class="fas fa-map-marker-alt text-red-400"></i>
                            {{ hopital.adresse }}
                        </p>
                    </div>
                    <div class="flex gap-2 flex-shrink-0">
                        <a href="{{ path('app_rendez_vous_new') }}"
                           class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition shadow text-sm">
                            <i class="fas fa-calendar-plus"></i> Prendre RDV
                        </a>
                        <a href="{{ path('frontoffice_hopitaux') }}"
                           class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 font-semibold rounded-lg hover:bg-gray-200 transition text-sm">
                            <i class="fas fa-arrow-left"></i> Retour
                        </a>
                    </div>
                </div>

                {# ── Layout principal : Carte + Infos ── #}
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

                    {# ── Carte Google Maps (3/5) ── #}
                    <div class="lg:col-span-3 space-y-3">

                        {# Badge API #}
                        <div class="flex items-center gap-2">
                            <span class="flex items-center gap-1.5 px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full border border-blue-200">
                                <i class="fab fa-google text-xs"></i> Google Maps API
                            </span>
                            {% if hopital.latitude and hopital.longitude %}
                                <span class="text-xs text-gray-400">
                                    {{ hopital.latitude|number_format(4) }}, {{ hopital.longitude|number_format(4) }}
                                </span>
                            {% endif %}
                        </div>

                        {# Carte principale #}
                        <div class="bg-white rounded-2xl border border-gray-200 shadow-md overflow-hidden">
                            {% if hopital.latitude and hopital.longitude %}
                                {# Onglets : Plan / Satellite / Street View #}
                                <div class="flex border-b border-gray-100">
                                    <button onclick="switchMapType('roadmap')"
                                            id="btn-road"
                                            class="flex-1 py-2.5 text-xs font-semibold text-blue-600 border-b-2 border-blue-600 transition">
                                        <i class="fas fa-map mr-1"></i>Plan
                                    </button>
                                    <button onclick="switchMapType('satellite')"
                                            id="btn-satellite"
                                            class="flex-1 py-2.5 text-xs font-semibold text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition">
                                        <i class="fas fa-satellite mr-1"></i>Satellite
                                    </button>
                                    <button onclick="switchMapType('hybrid')"
                                            id="btn-hybrid"
                                            class="flex-1 py-2.5 text-xs font-semibold text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition">
                                        <i class="fas fa-layer-group mr-1"></i>Hybride
                                    </button>
                                </div>
                                <div id="mapDetail" style="height: 380px; width: 100%;"></div>

                                {# Actions sur la carte #}
                                <div class="p-3 bg-gray-50 flex flex-wrap gap-2">
                                    <a href="https://www.google.com/maps/dir/?api=1&destination={{ hopital.latitude }},{{ hopital.longitude }}"
                                       target="_blank"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 text-gray-700 text-xs font-semibold rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-700 transition">
                                        <i class="fas fa-route text-blue-500"></i> Itinéraire
                                    </a>
                                    <a href="https://www.google.com/maps/search/?api=1&query={{ hopital.latitude }},{{ hopital.longitude }}"
                                       target="_blank"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 text-gray-700 text-xs font-semibold rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-700 transition">
                                        <i class="fas fa-external-link-alt text-blue-500"></i> Ouvrir Maps
                                    </a>
                                    <button onclick="map.setZoom(map.getZoom() + 2)"
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 text-gray-700 text-xs font-semibold rounded-lg hover:bg-gray-100 transition">
                                        <i class="fas fa-search-plus text-gray-500"></i> Zoom +
                                    </button>
                                </div>
                            {% else %}
                                <div class="h-80 flex flex-col items-center justify-center bg-gray-50 gap-4">
                                    <i class="fas fa-map-marked-alt text-gray-300 text-5xl"></i>
                                    <div class="text-center">
                                        <p class="text-gray-600 font-semibold">Coordonnées GPS non renseignées</p>
                                        <p class="text-gray-400 text-sm mt-1">Ajoutez latitude et longitude dans la base de données</p>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    {# ── Informations (2/5) ── #}
                    <div class="lg:col-span-2 space-y-4">

                        {# Fiche infos #}
                        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5">
                            <h2 class="text-base font-bold text-gray-900 mb-4 flex items-center gap-2">
                                <i class="fas fa-info-circle text-blue-500"></i> Informations
                            </h2>
                            <div class="space-y-3">
                                <div class="flex items-start gap-3">
                                    <div class="w-9 h-9 bg-red-50 rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-map-marker-alt text-red-500"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-400 font-medium mb-0.5">Adresse</p>
                                        <p class="text-sm text-gray-900 font-semibold">{{ hopital.adresse }}</p>
                                    </div>
                                </div>

                                <div class="flex items-start gap-3">
                                    <div class="w-9 h-9 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-phone text-green-500"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-400 font-medium mb-0.5">Téléphone</p>
                                        <a href="tel:{{ hopital.tel }}"
                                           class="text-sm text-green-700 font-bold hover:text-green-600 transition">
                                            {{ hopital.tel }}
                                        </a>
                                    </div>
                                </div>

                                {% if hopital.capacite %}
                                <div class="flex items-start gap-3">
                                    <div class="w-9 h-9 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-bed text-blue-500"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-400 font-medium mb-0.5">Capacité</p>
                                        <p class="text-sm text-gray-900 font-semibold">{{ hopital.capacite }} lits</p>
                                    </div>
                                </div>
                                {% endif %}

                                <div class="flex items-start gap-3">
                                    <div class="w-9 h-9 {% if hopital.serviceUrgenceDispo %}bg-green-50{% else %}bg-gray-50{% endif %} rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-ambulance {% if hopital.serviceUrgenceDispo %}text-green-500{% else %}text-gray-300{% endif %}"></i>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-400 font-medium mb-0.5">Service d'urgences</p>
                                        <p class="text-sm font-bold {% if hopital.serviceUrgenceDispo %}text-green-700{% else %}text-gray-400{% endif %}">
                                            {{ hopital.serviceUrgenceDispo ? 'Disponible 24h/24 — 7j/7' : 'Non disponible' }}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Spécialités #}
                        {% if hopital.specialites %}
                        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5">
                            <h2 class="text-base font-bold text-gray-900 mb-3 flex items-center gap-2">
                                <i class="fas fa-stethoscope text-purple-500"></i> Spécialités
                            </h2>
                            <div class="flex flex-wrap gap-2">
                                {% for spec in hopital.getSpecialitesArray() %}
                                    <span class="px-3 py-1.5 bg-purple-50 text-purple-800 text-xs font-semibold rounded-full border border-purple-100">
                                        {{ spec }}
                                    </span>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}

                        {# CTA Appel + RDV #}
                        <div class="space-y-2">
                            <a href="tel:{{ hopital.tel }}"
                               class="flex items-center justify-center gap-2 w-full px-5 py-3 bg-green-600 text-white font-bold rounded-xl hover:bg-green-700 transition shadow-md">
                                <i class="fas fa-phone-alt"></i> Appeler maintenant
                            </a>
                            <a href="{{ path('app_rendez_vous_new') }}"
                               class="flex items-center justify-center gap-2 w-full px-5 py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition shadow-md">
                                <i class="fas fa-calendar-plus"></i> Prendre un rendez-vous
                            </a>
                            <a href="https://www.google.com/maps/dir/?api=1&destination={{ hopital.latitude }},{{ hopital.longitude }}"
                               target="_blank"
                               class="flex items-center justify-center gap-2 w-full px-5 py-3 bg-white border border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition">
                                <i class="fas fa-route text-blue-500"></i> Calculer l'itinéraire
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if hopital.latitude and hopital.longitude %}
<script>
let map;

function initMapDetail() {
    const position = { lat: {{ hopital.latitude }}, lng: {{ hopital.longitude }} };

    map = new google.maps.Map(document.getElementById('mapDetail'), {
        zoom: 16,
        center: position,
        mapTypeId: 'roadmap',
        mapTypeControl: false,
        streetViewControl: true,
        fullscreenControl: true,
    });

    // Marqueur personnalisé
    const marker = new google.maps.Marker({
        position: position,
        map: map,
        title: '{{ hopital.nom|e("js") }}',
        animation: google.maps.Animation.DROP,
        icon: {
            path: google.maps.SymbolPath.CIRCLE,
            fillColor: '{{ hopital.serviceUrgenceDispo ? "#ef4444" : "#3b82f6" }}',
            fillOpacity: 1,
            strokeColor: '#ffffff',
            strokeWeight: 4,
            scale: 14,
        }
    });

    // Info-bulle ouverte par défaut
    const infoWindow = new google.maps.InfoWindow({
        content: `
            <div style="font-family:system-ui;padding:8px;max-width:220px;">
                <p style="font-weight:700;font-size:14px;color:#1e3a8a;margin:0 0 6px;">
                    {{ hopital.nom|e("js") }}
                </p>
                <p style="font-size:12px;color:#6b7280;margin:2px 0;">
                    📍 {{ hopital.adresse|e("js") }}
                </p>
                <p style="font-size:12px;color:#6b7280;margin:2px 0;">
                    📞 {{ hopital.tel|e("js") }}
                </p>
                <span style="display:inline-block;margin-top:6px;
                             background:{{ hopital.serviceUrgenceDispo ? "#dcfce7" : "#f3f4f6" }};
                             color:{{ hopital.serviceUrgenceDispo ? "#166534" : "#6b7280" }};
                             padding:3px 10px;border-radius:12px;font-size:11px;font-weight:600;">
                    {{ hopital.serviceUrgenceDispo ? "🚑 Urgences 24/7" : "Sans urgences" }}
                </span>
            </div>`
    });
    infoWindow.open(map, marker);
    marker.addListener('click', () => infoWindow.open(map, marker));
}

// Changer le type de carte
function switchMapType(type) {
    if (!map) return;
    map.setMapTypeId(type);
    ['road', 'satellite', 'hybrid'].forEach(t => {
        const btn = document.getElementById('btn-' + t);
        if (btn) {
            const isActive = (t === 'road' && type === 'roadmap') || t === type;
            btn.className = isActive
                ? 'flex-1 py-2.5 text-xs font-semibold text-blue-600 border-b-2 border-blue-600 transition'
                : 'flex-1 py-2.5 text-xs font-semibold text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition';
        }
    });
}
</script>

{# ✅ Google Maps JavaScript API — Remplacez VOTRE_CLE_API #}
<script
    src="https://maps.googleapis.com/maps/api/js?key=VOTRE_CLE_API&callback=initMapDetail&loading=async"
    async defer>
</script>
{% endif %}
{% endblock %}
